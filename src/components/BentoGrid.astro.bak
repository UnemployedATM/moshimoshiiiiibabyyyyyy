---
// BentoGrid.astro — Bento portfolio with flippable client cards
// CV data from Pablo_J_Michel_CV_2026.docx on each card's back face
---

<div class="hero" aria-hidden="false">
  <div class="bento-grid">

    <!-- ================================================ -->
    <!-- AGENTS — Kaiba Digital (AI System Design)        -->
    <!-- ================================================ -->
    <div class="bento-card search-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front agents-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <div class="tab-label">AGENTS</div>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content">
            <span class="back-badge agents-accent">2023 &ndash; Present</span>
            <h3 class="back-company">Kaiba Digital</h3>
            <p class="back-role">AI System Designer</p>
            <span class="back-meta">Mexico</span>
            <div class="back-divider"></div>
            <p class="back-desc">AI-assisted production pipelines, brand systems, and content workflows. Local LLM deployments and automation tooling for creative teams.</p>
            <div class="back-tags">
              <span class="back-tag">Ollama</span>
              <span class="back-tag">n8n</span>
              <span class="back-tag">Open WebUI</span>
              <span class="back-tag">Prompt Eng.</span>
              <span class="back-tag">LLM Pipelines</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- BRAND — Kaiba Digital (Graphic Design / Brand)   -->
    <!-- ================================================ -->
    <div class="bento-card portfolios-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front brand-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <div class="tab-label">BRAND</div>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content compact">
            <span class="back-badge brand-accent">2023 &ndash; Present</span>
            <h3 class="back-company">Kaiba Digital</h3>
            <p class="back-role">Graphic Designer</p>
            <span class="back-meta">Mexico</span>
            <div class="back-tags">
              <span class="back-tag">Figma</span>
              <span class="back-tag">Brand Identity</span>
              <span class="back-tag">Design Systems</span>
              <span class="back-tag">Social Content</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- design is my passion — Sound & Creative          -->
    <!-- ================================================ -->
    <div class="bento-card guild-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front design-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <div class="tab-label is-comic">design is my passion</div>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content compact">
            <h3 class="back-company">Sound &amp; Creative</h3>
            <div class="client-list">
              <div class="client-entry" style="border-left-color: #00D287;">
                <div class="entry-info">
                  <strong>Dai Blue</strong>
                  <span class="entry-meta">Composer &amp; Sound Designer</span>
                  <span class="entry-meta">2023 &ndash; Present &middot; MX / CN / CO</span>
                </div>
                <span class="entry-status active" style="border-color: #00D287; background: #00D287;"></span>
              </div>
              <div class="client-entry" style="border-left-color: #00D287;">
                <div class="entry-info">
                  <strong>Radio Ibero</strong>
                  <span class="entry-meta">Sound Design</span>
                  <span class="entry-meta">2023 &middot; Mexico</span>
                </div>
                <span class="entry-status" style="border-color: #aaa;"></span>
              </div>
              <div class="client-entry" style="border-left-color: #00D287;">
                <div class="entry-info">
                  <strong>Dai Blue</strong>
                  <span class="entry-meta">2D Compositor</span>
                  <span class="entry-meta">2023 &middot; MX / CN / CO</span>
                </div>
                <span class="entry-status" style="border-color: #aaa;"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- /Pablo Michel — TITLE (no flip)                  -->
    <!-- ================================================ -->
    <div class="bento-card uipedia-card interactive-card flex-center">
      <h1 class="logo-title"><span>/P</span>ablo <span class="serif">Michel</span></h1>
    </div>

    <!-- ================================================ -->
    <!-- EDITOR — Video Editing Clients                   -->
    <!-- ================================================ -->
    <div class="bento-card dashboard-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front editor-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <div class="tab-label">EDITOR</div>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content compact">
            <h3 class="back-company">Video Editing</h3>
            <div class="client-list tight">
              <div class="client-entry" style="border-left-color: #00B4DB;">
                <div class="entry-info">
                  <strong>Ozone Media</strong>
                  <span class="entry-meta">2024 &ndash; Present &middot; Remote</span>
                </div>
                <span class="entry-status active" style="border-color: #00B4DB; background: #00B4DB;"></span>
              </div>
              <div class="client-entry" style="border-left-color: #00B4DB;">
                <div class="entry-info">
                  <strong>QuillCut Media</strong>
                  <span class="entry-meta">2024 &ndash; Present &middot; Remote</span>
                </div>
                <span class="entry-status active" style="border-color: #00B4DB; background: #00B4DB;"></span>
              </div>
              <div class="client-entry" style="border-left-color: #00B4DB;">
                <div class="entry-info">
                  <strong>Dai Blue</strong>
                  <span class="entry-meta">2023 &ndash; Present &middot; MX / CN / CO</span>
                </div>
                <span class="entry-status active" style="border-color: #00B4DB; background: #00B4DB;"></span>
              </div>
              <div class="client-entry" style="border-left-color: #ccc;">
                <div class="entry-info">
                  <strong>WekaSuwi</strong>
                  <span class="entry-meta">2023 &ndash; 2024</span>
                </div>
                <span class="entry-status" style="border-color: #ccc;"></span>
              </div>
              <div class="client-entry" style="border-left-color: #ccc;">
                <div class="entry-info">
                  <strong>Kjar Crew</strong>
                  <span class="entry-meta">2022 &ndash; 2024</span>
                </div>
                <span class="entry-status" style="border-color: #ccc;"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- LET'S TALK — Contact                             -->
    <!-- ================================================ -->
    <div class="bento-card resources-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front contact-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <div class="tab-label">LET'S TALK</div>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content compact centered">
            <a href="mailto:pablomichelmr@gmail.com" class="contact-link">pablomichelmr<wbr>@gmail.com</a>
            <a href="tel:+5214431311173" class="contact-link subtle">+52 1 443 131 1173</a>
            <span class="back-meta">Mexico</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- Subtitle — Education & Languages                 -->
    <!-- ================================================ -->
    <div class="bento-card gradient-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front subtitle-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <h2 class="subtitle">Interfaces, &amp; the intelligence within.</h2>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content row-layout">
            <div class="back-section">
              <h3 class="back-company">Education</h3>
              <p class="back-role">B.A. Film Production</p>
              <span class="back-meta">CAAV &middot; 2018 &ndash; 2021 &middot; Mexico</span>
            </div>
            <div class="back-section-divider"></div>
            <div class="back-section">
              <h3 class="back-company">Languages</h3>
              <div class="lang-row">
                <div class="lang-item">
                  <span class="lang-label">Spanish</span>
                  <span class="lang-level">Native</span>
                </div>
                <div class="lang-item">
                  <span class="lang-label">English</span>
                  <span class="lang-level">C1 Fluent</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- Bio — Skills                                     -->
    <!-- ================================================ -->
    <div class="bento-card explore-card flip-card" data-flip>
      <div class="flip-inner">
        <div class="flip-front bio-front">
          <span class="flip-hint" aria-hidden="true"></span>
          <div class="bio-text">
            <p>Working out of Mexico, fluent across LATAM and global English-speaking markets.</p>
            <p>I design end-to-end products; from user research to production code with AI tooling threading through every layer of the work.</p>
            <p class="italic">Serial builder of small, careful systems.</p>
          </div>
        </div>
        <div class="flip-back">
          <button class="flip-close" aria-label="Flip back">&larr;</button>
          <div class="back-content">
            <h3 class="back-company">Skills</h3>
            <div class="skills-grid">
              <div class="skill-group">
                <h4 class="skill-cat">Editing &amp; Color</h4>
                <p class="skill-tools">Premiere Pro &middot; DaVinci Resolve &middot; CapCut &middot; Final Cut</p>
              </div>
              <div class="skill-group">
                <h4 class="skill-cat">Motion &amp; Compositing</h4>
                <p class="skill-tools">After Effects &middot; Illustrator &middot; Cinema 4D &middot; Blender &middot; Clip Studio</p>
              </div>
              <div class="skill-group">
                <h4 class="skill-cat">Sound &amp; Music</h4>
                <p class="skill-tools">Studio One &middot; Ableton &middot; Cubase &middot; Audition</p>
              </div>
              <div class="skill-group">
                <h4 class="skill-cat">AI &amp; Automation</h4>
                <p class="skill-tools">Ollama &middot; n8n &middot; Open WebUI &middot; LLM Pipelines</p>
              </div>
              <div class="skill-group">
                <h4 class="skill-cat">Design &amp; Branding</h4>
                <p class="skill-tools">Figma &middot; Brand Identity &middot; Design Tokens</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  // Flip-card interaction: click to flip, only one open at a time,
  // Escape to close, links pass through without flipping.

  const flipCards = document.querySelectorAll<HTMLElement>('.flip-card');

  flipCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Let real links work without flipping
      if (target.closest('a')) return;

      // Close button — unflip this card only
      if (target.closest('.flip-close')) {
        card.classList.remove('is-flipped');
        return;
      }

      // Unflip every other card first
      flipCards.forEach(c => {
        if (c !== card) c.classList.remove('is-flipped');
      });

      // Toggle this card
      card.classList.toggle('is-flipped');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      flipCards.forEach(c => c.classList.remove('is-flipped'));
    }
  });
</script>

<style>
  /* =============================================
     LAYOUT
     ============================================= */
  .hero {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #000;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(13, 1fr);
    grid-template-rows: 3fr 4fr 3fr;
    gap: 1.5cqw;
    width: 100%;
    height: 100%;
    padding: 3cqw;
    box-sizing: border-box;
  }

  /* =============================================
     GRID POSITIONS
     ============================================= */
  .search-card     { grid-column: 1 / 4;   grid-row: 1 / 3; }
  .portfolios-card { grid-column: 1 / 4;   grid-row: 3 / 4; }
  .guild-card      { grid-column: 4 / 8;   grid-row: 1 / 2; }
  .uipedia-card    { grid-column: 4 / 10;  grid-row: 2 / 3; }
  .dashboard-card  { grid-column: 4 / 8;   grid-row: 3 / 4; }
  .resources-card  { grid-column: 8 / 10;  grid-row: 3 / 4; }
  .gradient-card   { grid-column: 8 / 14;  grid-row: 1 / 2; }
  .explore-card    { grid-column: 10 / 14; grid-row: 2 / 4; }

  /* =============================================
     BASE CARD
     ============================================= */
  .bento-card {
    border-radius: 1.5cqw;
    position: relative;
    color: #fff;
  }

  /* Static (non-flip) card */
  .bento-card:not(.flip-card) {
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 1cqw 3cqw rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }

  .flex-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  /* =============================================
     FLIP CARD — 3D MECHANICS
     ============================================= */
  .flip-card {
    perspective: 120cqw;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .flip-inner {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .flip-card.is-flipped .flip-inner {
    transform: rotateY(180deg);
  }

  .flip-front,
  .flip-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 1.5cqw;
    overflow: hidden;
  }

  /* =============================================
     FRONT FACE
     ============================================= */
  .flip-front {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: 0 1cqw 3cqw rgba(0, 0, 0, 0.4);
    transition: box-shadow 0.3s ease, filter 0.3s ease;
  }

  .agents-front   { background: #C89BFF; color: #111; }
  .brand-front    { background: #FF4B2B; color: #fff; }
  .design-front   { background: #00D287; color: #111; }
  .editor-front   { background: #00B4DB; color: #111; }
  .contact-front  { background: #FFC107; color: #111; }
  .subtitle-front { background: #FF007F; color: #fff; }
  .bio-front      { background: #2B2B3C; color: #fff; align-items: stretch; }

  /* Front face hover — lift + glow */
  .flip-card:not(.is-flipped):hover .flip-front {
    filter: brightness(1.1);
    box-shadow: 0 1.4cqw 4.5cqw rgba(0, 0, 0, 0.55);
  }

  .flip-card:not(.is-flipped):hover .tab-label {
    transform: scale(1.08);
  }

  /* Flip hint dot — bottom-right, fades in on hover */
  .flip-hint {
    position: absolute;
    bottom: 0.8cqw;
    right: 0.8cqw;
    width: 0.55cqw;
    height: 0.55cqw;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.2;
    transition: opacity 0.3s;
  }

  .flip-card:not(.is-flipped):hover .flip-hint {
    opacity: 0.6;
  }

  /* =============================================
     FRONT FACE — CONTENT ELEMENTS
     ============================================= */
  .tab-label {
    font-weight: 700;
    font-family: 'Avenir Next', system-ui, sans-serif;
    font-size: 2.5cqw;
    letter-spacing: 0.05em;
    z-index: 2;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tab-label.is-comic {
    font-family: 'Comic Sans MS', 'Comic Neue', 'Marker Felt', cursive;
    font-size: 1.8cqw;
    font-weight: 400;
  }

  .subtitle {
    font-family: 'Avenir Next', sans-serif;
    font-weight: 400;
    font-size: 2.2cqw;
    max-width: 80%;
  }

  .bio-text {
    padding: 2.5cqw;
    text-align: left;
  }

  .bio-text p {
    font-size: 1.4cqw;
    line-height: 1.5;
    margin-bottom: 1.2cqw;
    color: #ddd;
  }

  .bio-text .italic {
    font-style: italic;
    color: #aaa;
  }

  /* =============================================
     BACK FACE — warm cream (screenshot ref)
     ============================================= */
  .flip-back {
    transform: rotateY(180deg);
    background: #F5EFE6;
    color: #2A2A2A;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 1cqw 3cqw rgba(0, 0, 0, 0.25);
    font-family: 'Avenir Next', system-ui, sans-serif;
  }

  /* =============================================
     BACK FACE — CONTENT
     ============================================= */
  .back-content {
    padding: 2cqw;
    height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .back-content.compact {
    padding: 1.4cqw;
  }

  .back-content.centered {
    align-items: center;
    justify-content: center;
  }

  .back-content.row-layout {
    flex-direction: row;
    align-items: center;
    gap: 2cqw;
  }

  /* Badge — pill (like "May 12, 2023" in the SS) */
  .back-badge {
    display: inline-block;
    align-self: flex-start;
    padding: 0.25cqw 0.85cqw;
    border-radius: 10cqw;
    font-size: 0.8cqw;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 0.6cqw;
  }

  .agents-accent { background: #C89BFF; color: #1a1a2e; }
  .brand-accent  { background: #FF4B2B; color: #fff; }

  .back-company {
    font-size: 1.8cqw;
    font-weight: 700;
    margin-bottom: 0.2cqw;
    line-height: 1.2;
    color: #1A1A1A;
  }

  .compact .back-company {
    font-size: 1.35cqw;
  }

  .back-role {
    font-size: 1.05cqw;
    color: #666;
    margin-bottom: 0.2cqw;
  }

  .compact .back-role {
    font-size: 0.9cqw;
  }

  .back-meta {
    font-size: 0.85cqw;
    color: #999;
    margin-bottom: 0.4cqw;
    display: block;
  }

  .back-divider {
    width: 100%;
    height: 1px;
    background: rgba(0, 0, 0, 0.08);
    margin: 0.7cqw 0;
    flex-shrink: 0;
  }

  .compact .back-divider {
    margin: 0.4cqw 0;
  }

  .back-desc {
    font-size: 1cqw;
    line-height: 1.55;
    color: #555;
    margin-bottom: 0.7cqw;
  }

  /* Tags */
  .back-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3cqw;
    margin-top: auto;
  }

  .back-tag {
    padding: 0.2cqw 0.6cqw;
    border-radius: 0.4cqw;
    font-size: 0.72cqw;
    font-weight: 500;
    background: rgba(0, 0, 0, 0.06);
    color: #555;
  }

  /* =============================================
     CLIENT LIST — flight-entry style from SS
     ============================================= */
  .client-list {
    display: flex;
    flex-direction: column;
    gap: 0.45cqw;
    margin-top: 0.5cqw;
    flex: 1;
    min-height: 0;
  }

  .client-list.tight {
    gap: 0.3cqw;
  }

  .client-entry {
    display: flex;
    align-items: center;
    gap: 0.5cqw;
    padding: 0.45cqw 0.65cqw;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 0.6cqw;
    border-left: 0.3cqw solid #ccc;
    flex-shrink: 0;
  }

  .entry-info {
    flex: 1;
    min-width: 0;
  }

  .entry-info strong {
    font-size: 0.9cqw;
    display: block;
    color: #2A2A2A;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tight .entry-info strong {
    font-size: 0.8cqw;
  }

  .entry-meta {
    font-size: 0.7cqw;
    color: #999;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tight .entry-meta {
    font-size: 0.65cqw;
  }

  /* Status circle (like the hour-ring in the SS) */
  .entry-status {
    width: 1cqw;
    height: 1cqw;
    border-radius: 50%;
    border: 0.18cqw solid #ccc;
    flex-shrink: 0;
    background: transparent;
  }

  .entry-status.active {
    /* background + border set inline for per-entry color */
  }

  /* =============================================
     CONTACT CARD BACK
     ============================================= */
  .contact-link {
    display: block;
    font-size: 0.85cqw;
    font-weight: 600;
    color: #2A2A2A;
    text-decoration: none;
    margin-bottom: 0.25cqw;
    transition: color 0.2s;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .contact-link:hover {
    color: #FF4B2B;
  }

  .contact-link.subtle {
    font-weight: 400;
    font-size: 0.8cqw;
    color: #666;
  }

  .contact-link.subtle:hover {
    color: #333;
  }

  /* =============================================
     EDUCATION / LANGUAGES — row layout
     ============================================= */
  .back-section {
    flex: 1;
  }

  .back-section-divider {
    width: 1px;
    align-self: stretch;
    background: rgba(0, 0, 0, 0.08);
    flex-shrink: 0;
  }

  .lang-row {
    display: flex;
    gap: 1.5cqw;
    margin-top: 0.4cqw;
  }

  .lang-item {
    display: flex;
    flex-direction: column;
  }

  .lang-label {
    font-size: 1cqw;
    font-weight: 600;
    color: #2A2A2A;
  }

  .lang-level {
    font-size: 0.85cqw;
    color: #888;
  }

  /* =============================================
     SKILLS GRID (bio back)
     ============================================= */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 0.9cqw;
