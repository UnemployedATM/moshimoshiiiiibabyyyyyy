---
// KinecenterCuestionario.astro
// Renders the Kinecenter "Cuestionario de Ejecución" form.
// If `answers` is provided, the form renders read-only with the answers shown.
// Otherwise, it shows the empty form which POSTs to /api/brief/questionnaire.

interface KinecenterAnswers {
  broll?: string[];
  broll_other?: string;
  pacientes_real?: string;
  offer?: string;
  offer_other?: string;
  objecion_principal?: string;
  temporada?: string;
  competencia?: string;
  rodaje?: string;
  rodaje_other?: string;
  vestuario?: string;
}

interface Props {
  token: string;
  answers: KinecenterAnswers | null;
  submittedAt: string | null;
}

const { token, answers, submittedAt } = Astro.props;
const isLocked = !!answers;

const v = (key: keyof KinecenterAnswers) => (answers ? (answers as any)[key] : undefined);
const broll = (answers?.broll || []) as string[];
const isChecked = (name: keyof KinecenterAnswers, value: string) => {
  if (name === 'broll') return broll.includes(value);
  return v(name) === value;
};
const submittedDate = submittedAt
  ? new Date(submittedAt).toLocaleString('es-MX', {
      day: '2-digit', month: 'short', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    })
  : null;
---

<style is:global>
  .kc-host{
    color-scheme:dark;
    --kc-black:#000;--kc-paper:#0d0d10;--kc-card:#141417;--kc-card-2:#191920;--kc-slate:#2c2b3b;
    --kc-line:rgba(255,255,255,.08);--kc-line-2:rgba(255,255,255,.14);
    --kc-ink:#0a0a0d;--kc-white:#f4f4f6;--kc-mut:#a6a6b2;--kc-mut-2:#74747f;
    --kc-cyan:#02b6db;--kc-green:#00d287;--kc-pink:#ff0080;--kc-orange:#f84828;
    --kc-yellow:#f8c000;--kc-lav:#c898f8;--kc-violet:#8870f8;
    --kc-r:24px;--kc-r-sm:16px;
    --kc-sans:"Archivo",-apple-system,BlinkMacSystemFont,sans-serif;
    --kc-serif:"Fraunces",Georgia,serif;
    --kc-hand:"Caveat",cursive;
    background:transparent;color:var(--kc-white);
    font-family:var(--kc-sans);font-size:16px;line-height:1.6;
    display:block;padding:0;
  }
  .kc-wrap{width:100%;margin:0 auto}

  .kc-topbar{display:flex;justify-content:space-between;align-items:center;padding:6px 10px 20px;font-size:13px;color:var(--kc-mut-2);font-weight:500;flex-wrap:wrap;gap:8px}
  .kc-topbar .kc-mark{color:var(--kc-white);font-weight:700;letter-spacing:-.01em}
  .kc-topbar .kc-mark .kc-sl{color:var(--kc-violet)}
  .kc-topbar .kc-tag{border:1px solid var(--kc-line-2);border-radius:50px;padding:5px 13px;color:var(--kc-mut);font-weight:600;font-size:12px;letter-spacing:.04em}

  .kc-grid{display:grid;gap:14px}
  @media(max-width:640px){.kc-grid{gap:10px}}
  .kc-tile{border-radius:var(--kc-r);padding:clamp(18px,2vw,28px);position:relative;overflow:hidden;box-shadow:0 18px 40px -22px rgba(0,0,0,.8);min-width:0}
  .kc-tile::after{content:"";position:absolute;right:14px;bottom:14px;width:8px;height:8px;border-radius:50%;background:currentColor;opacity:.32}
  .kc-tile.no-dot::after{display:none}
  .kc-t-cyan{background:var(--kc-cyan);color:var(--kc-ink)}
  .kc-t-green{background:var(--kc-green);color:var(--kc-ink)}
  .kc-t-pink{background:var(--kc-pink);color:#fff}
  .kc-t-orange{background:var(--kc-orange);color:#fff}
  .kc-t-yellow{background:var(--kc-yellow);color:var(--kc-ink)}
  .kc-t-lav{background:var(--kc-lav);color:var(--kc-ink)}
  .kc-t-slate{background:var(--kc-slate);color:var(--kc-white)}

  .kc-blab{font-weight:900;text-transform:uppercase;letter-spacing:-.02em;line-height:.92;word-break:break-word;hyphens:auto}

  .kc-hero{grid-template-columns:1.1fr 1.6fr 1fr;grid-auto-rows:minmax(118px,auto);
    grid-template-areas:"cyan green pink" "cyan name slate" "orange lav slate" "yel lav slate"}
  .kc-h-cyan{grid-area:cyan;display:flex;flex-direction:column;justify-content:flex-end}
  .kc-h-green{grid-area:green;display:flex;align-items:center;justify-content:center;text-align:center}
  .kc-h-pink{grid-area:pink;display:flex;align-items:center}
  .kc-h-name{grid-area:name;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;background:var(--kc-card);border:1px solid var(--kc-line)}
  .kc-h-slate{grid-area:slate;display:flex;flex-direction:column;justify-content:center;border:1px solid var(--kc-line)}
  .kc-h-orange{grid-area:orange}.kc-h-lav{grid-area:lav}.kc-h-yel{grid-area:yel}
  .kc-h-cyan .kc-big{font-size:clamp(26px,2.6vw,40px)}
  .kc-h-cyan .kc-k{font-size:11.5px;letter-spacing:.24em;text-transform:uppercase;font-weight:700;opacity:.7;margin-bottom:14px}
  .kc-h-green .kc-hand{font-family:var(--kc-hand);font-weight:700;font-size:clamp(28px,3.2vw,46px);line-height:.95}
  .kc-h-pink .kc-t{font-size:clamp(15px,1.6vw,21px);font-weight:600;line-height:1.18;letter-spacing:-.01em}
  .kc-h-pink .kc-t b{font-weight:800}
  .kc-h-name .kc-wm{font-weight:900;font-size:clamp(30px,3.6vw,54px);letter-spacing:-.04em;line-height:.9}
  .kc-h-name .kc-wm .kc-sl{color:var(--kc-violet)}
  .kc-h-name .kc-wm .kc-se{font-family:var(--kc-serif);font-weight:400}
  .kc-h-name .kc-sub{margin-top:12px;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--kc-mut);font-weight:600}
  .kc-h-slate p{font-size:14px;line-height:1.55;color:var(--kc-white)}
  .kc-h-slate p+p{margin-top:10px}
  .kc-h-slate .kc-em{font-weight:700}
  .kc-h-slate .kc-it{font-style:italic;font-family:var(--kc-serif);color:var(--kc-mut)}
  .kc-h-stat{display:flex;flex-direction:column;justify-content:center}
  .kc-h-stat .kc-n{font-weight:900;font-size:clamp(22px,2.4vw,34px);letter-spacing:-.03em;line-height:1}
  .kc-h-stat .kc-l{font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;margin-top:6px;opacity:.78;line-height:1.3}

  .kc-nota{margin-top:14px;background:color-mix(in srgb,var(--kc-orange) 12%,var(--kc-card));border:1px solid var(--kc-line);border-left:4px solid var(--kc-orange);border-radius:var(--kc-r-sm);padding:22px 26px}
  .kc-nota .kc-nt{font-weight:800;color:var(--kc-orange);font-size:12.5px;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px}
  .kc-nota p{color:var(--kc-mut);font-size:14.5px;line-height:1.6}
  .kc-nota p strong{color:var(--kc-white);font-weight:700}
  .kc-nota p em{color:var(--kc-white);font-style:italic}

  .kc-locked-bar{margin-top:14px;background:color-mix(in srgb,var(--kc-green) 14%,var(--kc-card));border:1px solid var(--kc-green);border-radius:var(--kc-r-sm);padding:20px 26px;display:flex;justify-content:space-between;align-items:center;gap:18px;flex-wrap:wrap}
  .kc-locked-bar .kc-l-l{font-weight:800;color:var(--kc-green);font-size:13px;letter-spacing:.06em;text-transform:uppercase}
  .kc-locked-bar .kc-l-d{color:var(--kc-mut);font-size:13px}

  .kc-sec{margin-top:18px}
  .kc-sec-tile{border-radius:var(--kc-r);padding:clamp(22px,2.4vw,32px) clamp(22px,2.6vw,36px);position:relative;overflow:hidden;display:flex;align-items:flex-end;justify-content:space-between;gap:20px;min-height:120px;box-shadow:0 18px 40px -22px rgba(0,0,0,.8)}
  .kc-sec-tile::after{content:"";position:absolute;right:16px;bottom:16px;width:8px;height:8px;border-radius:50%;background:currentColor;opacity:.3}
  .kc-sec-tile .kc-left{display:flex;flex-direction:column;min-width:0}
  .kc-sec-tile .kc-no{font-family:var(--kc-serif);font-size:14px;font-weight:600;opacity:.6;margin-bottom:8px}
  .kc-sec-tile .kc-ttl{font-weight:900;text-transform:uppercase;letter-spacing:-.025em;line-height:.92;font-size:clamp(22px,2.8vw,40px);word-break:break-word}
  .kc-sec-tile .kc-meta{text-align:right;font-size:11.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;opacity:.62;white-space:nowrap}
  .kc-sec-body{margin-top:14px;display:grid;gap:14px}

  .kc-card{background:var(--kc-card);border:1px solid var(--kc-line);border-radius:var(--kc-r);padding:clamp(22px,2.4vw,32px) clamp(22px,2.4vw,34px)}

  .kc-qg{margin-bottom:30px}
  .kc-qg:last-child{margin-bottom:0}
  .kc-qlab{display:block;font-weight:700;font-size:16px;color:var(--kc-white);margin-bottom:10px;line-height:1.45}
  .kc-qlab strong{font-weight:800}
  .kc-why{display:block;font-size:13px;color:var(--kc-mut);background:var(--kc-card-2);border-left:3px solid var(--kc-accent,var(--kc-cyan));border-radius:0 8px 8px 0;padding:12px 16px;margin-bottom:16px;line-height:1.55}
  .kc-why strong{color:var(--kc-accent,var(--kc-cyan));font-weight:700}

  .kc-fld{width:100%;padding:14px 16px;border:1px solid var(--kc-line-2);border-radius:12px;background:var(--kc-card-2);color:var(--kc-white);font-family:inherit;font-size:15px;transition:border-color .18s,box-shadow .18s,background .18s}
  .kc-fld::placeholder{color:var(--kc-mut-2)}
  .kc-fld:focus{outline:none;border-color:var(--kc-accent,var(--kc-cyan));box-shadow:0 0 0 3px color-mix(in srgb,var(--kc-accent,var(--kc-cyan)) 24%,transparent);background:#1c1c22}
  .kc-fld:disabled{opacity:.95;cursor:default}
  textarea.kc-fld{min-height:96px;resize:vertical}
  select.kc-fld{appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%23a6a6b2' stroke-width='3'><path d='M6 9l6 6 6-6'/></svg>");background-repeat:no-repeat;background-position:right 16px center;padding-right:42px;cursor:pointer}

  .kc-other-wrap{margin-top:12px}
  .kc-other-lbl{display:block;font-size:11.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--kc-mut);margin-bottom:6px}
  .kc-other-lbl span{color:var(--kc-accent,var(--kc-cyan))}
  .kc-opts{display:flex;flex-direction:column;gap:11px}
  .kc-opt{display:flex;gap:14px;align-items:flex-start;padding:15px 18px;border:1px solid var(--kc-line);border-radius:14px;background:var(--kc-card-2);cursor:pointer;transition:border-color .16s,background .16s}
  .kc-opt:hover{border-color:var(--kc-line-2);background:#202027}
  .kc-opt:has(input:checked){border-color:var(--kc-accent,var(--kc-cyan));background:color-mix(in srgb,var(--kc-accent,var(--kc-cyan)) 13%,var(--kc-card))}
  .kc-opt input{margin-top:3px;width:18px;height:18px;accent-color:var(--kc-accent,var(--kc-cyan));flex:none;cursor:pointer}
  .kc-opt input:disabled{cursor:default}
  .kc-opt .kc-ot-t{font-weight:600;font-size:15px;color:var(--kc-white);line-height:1.4}
  .kc-opt .kc-ot-t strong{font-weight:800}
  .kc-opt .kc-ot-d{font-size:13px;color:var(--kc-mut);margin-top:4px;line-height:1.45}
  .kc-opt:has(input:checked) .kc-ot-d{color:var(--kc-white)}

  .kc-duo{grid-template-columns:1fr 1fr}
  @media(max-width:760px){.kc-duo{grid-template-columns:1fr}}

  .kc-btn{width:100%;margin-top:8px;padding:20px;border:none;border-radius:var(--kc-r-sm);background:var(--kc-orange);color:#fff;font-family:inherit;font-size:17px;font-weight:800;letter-spacing:.02em;text-transform:uppercase;cursor:pointer;transition:transform .18s,box-shadow .18s,opacity .18s;box-shadow:0 14px 30px -12px rgba(248,72,40,.6)}
  .kc-btn:hover{transform:translateY(-2px);box-shadow:0 20px 38px -12px rgba(248,72,40,.7)}
  .kc-btn:active{transform:translateY(0)}
  .kc-btn[disabled]{opacity:.6;cursor:not-allowed;transform:none}

  .kc-error{display:none;margin-top:14px;background:color-mix(in srgb,var(--kc-pink) 12%,var(--kc-card));border:1px solid var(--kc-pink);border-radius:14px;padding:14px 18px;color:#fff;font-size:14px}

  @media(max-width:900px){
    .kc-hero{
      grid-template-columns:1fr 1fr;
      grid-template-areas:
        "cyan   green"
        "cyan   pink"
        "name   name"
        "slate  slate"
        "orange lav"
        "yel    lav";
    }
    .kc-h-pink .kc-t{font-size:clamp(14px,2.4vw,18px)}
  }
  @media(max-width:600px){
    .kc-hero{
      grid-template-columns:1fr;
      grid-template-areas:
        "cyan"
        "green"
        "name"
        "pink"
        "slate"
        "orange"
        "lav"
        "yel";
    }
    .kc-h-cyan{min-height:140px}
    .kc-h-green{min-height:120px}
    .kc-h-name{padding:32px 20px}
    .kc-sec-tile{flex-direction:column;align-items:flex-start;gap:12px;min-height:auto}
    .kc-sec-tile .kc-meta{text-align:left}
  }
</style>

<div class="kc-host">
  <div class="kc-wrap">

    <div class="kc-topbar">
      <div class="kc-mark"><span class="kc-sl">/</span>pablojmichel.com</div>
      <div class="kc-tag">CUESTIONARIO · KINECENTER MX · v2.1</div>
    </div>

    <div class="kc-grid kc-hero">
      <div class="kc-tile kc-h-cyan kc-t-cyan">
        <div class="kc-k">Cuestionario de Ejecución</div>
        <div class="kc-blab kc-big">CREATIVIDAD<br/>&amp; PAID MEDIA</div>
      </div>
      <div class="kc-tile kc-h-green kc-t-green">
        <div class="kc-hand">definamos los<br/>assets exactos</div>
      </div>
      <div class="kc-tile kc-h-pink kc-t-pink">
        <div class="kc-t"><b>Activos, ofertas y logística</b> de rodaje para los primeros 3 meses.</div>
      </div>
      <div class="kc-tile kc-h-name no-dot">
        <div class="kc-wm"><span class="kc-sl">/</span>Kine<span class="kc-se">center</span></div>
        <div class="kc-sub">Fase de Producción Táctica</div>
      </div>
      <div class="kc-tile kc-h-slate kc-t-slate">
        <p><span class="kc-em">Definición de activos visuales,</span> ofertas comerciales y logística de rodaje (batching).</p>
        <p class="kc-it">Para Kinecenter MX · CDMX.</p>
      </div>
      <div class="kc-tile kc-h-stat kc-h-orange kc-t-orange"><div class="kc-n">2 / sem</div><div class="kc-l">1 orgánico + 1 paid</div></div>
      <div class="kc-tile kc-h-stat kc-h-lav kc-t-lav"><div class="kc-n">&lt;30s</div><div class="kc-l">Reels / TikToks</div></div>
      <div class="kc-tile kc-h-stat kc-h-yel kc-t-yellow"><div class="kc-n">Batching</div><div class="kc-l">Rodaje en bloques</div></div>
    </div>

    {isLocked ? (
      <div class="kc-locked-bar">
        <div>
          <div class="kc-l-l">✅ Brief de producción completado</div>
          <div class="kc-l-d">Respuestas enviadas{submittedDate ? ` el ${submittedDate}` : ''}. Para cambios, escribe a Pablo Michel.</div>
        </div>
        <div class="kc-l-d">Versión bloqueada · solo lectura</div>
      </div>
    ) : (
      <div class="kc-nota">
        <div class="kc-nt">⚠️ Nota Estratégica</div>
        <p>Ya definimos que publicaremos <strong>2 Reels/TikToks por semana</strong> (1 Orgánico, 1 Paid Media) de <strong>máximo 30 segundos</strong>, grabados en bloques intensivos (Batching). Para que el equipo de producción no pierda tiempo y los anuncios no sean rechazados por Meta, necesitamos definir los <em>ángulos de ataque</em>, las <em>ofertas de entrada</em> y los <em>activos visuales</em> exactos que usaremos en los primeros 3 meses.</p>
      </div>
    )}

    <form id="kc-form" data-token={token} data-locked={isLocked ? '1' : '0'}>

      <section class="kc-sec" style="--kc-accent:var(--kc-cyan)">
        <div class="kc-sec-tile kc-t-cyan">
          <div class="kc-left"><div class="kc-no">/ 01 — b-roll</div><div class="kc-ttl">Activos Visuales<br/>y B-Roll</div></div>
          <div class="kc-meta">Tomas de apoyo</div>
        </div>
        <div class="kc-sec-body">
          <div class="kc-card">
            <div class="kc-qg">
              <label class="kc-qlab">Además de la máquina Photon, ¿qué otros elementos de la clínica son "fotogénicos" o generan autoridad visual?</label>
              <span class="kc-why"><strong>Por qué lo preguntamos:</strong> Los videos de 30s necesitan cambios de plano cada 3-4 segundos para retener la atención. Necesitamos saber qué "B-Roll" (tomas de relleno) podemos grabar masivamente.</span>
              <div class="kc-opts">
                <label class="kc-opt"><input type="checkbox" name="broll" value="camillas" checked={isChecked('broll','camillas')} disabled={isLocked} /><div class="kc-ot-t">Camillas de masaje con iluminación cálida / toallas premium</div></label>
                <label class="kc-opt"><input type="checkbox" name="broll" value="equipo" checked={isChecked('broll','equipo')} disabled={isLocked} /><div class="kc-ot-t">Equipo de rehabilitación activa (pesas, bandas, balones médicos)</div></label>
                <label class="kc-opt"><input type="checkbox" name="broll" value="recepcion" checked={isChecked('broll','recepcion')} disabled={isLocked} /><div class="kc-ot-t">Recepción limpia, moderna y con buena atención al cliente</div></label>
                <label class="kc-opt"><input type="checkbox" name="broll" value="anatomia" checked={isChecked('broll','anatomia')} disabled={isLocked} /><div class="kc-ot-t">Modelos anatómicos, pizarras o iPads donde explican el dolor</div></label>
              </div>
              {(!isLocked || v('broll_other')) && (
                <div class="kc-other-wrap">
                  <label class="kc-other-lbl" for="kc_broll_other"><span>+</span> Otro / Especificar (opcional)</label>
                  <input type="text" id="kc_broll_other" name="broll_other" class="kc-fld" placeholder="Ej. Sala de espera con plantas y arte, mural con foto antes/después de pacientes..." value={v('broll_other') || ''} disabled={isLocked} />
                </div>
              )}
            </div>
            <div class="kc-qg">
              <label class="kc-qlab" for="kc_pacientes_real">¿Qué tan factible es grabar a pacientes reales (o actores/modelos simulando) para los videos de "Social Proof" y "Masaje"?</label>
              <span class="kc-why"><strong>Por qué lo preguntamos:</strong> Meta Ads prohíbe estrictamente mostrar "Antes/Después" de cuerpos o zoom a partes del cuerpo con dolor. Necesitamos saber si podemos mostrar rostros de alivio o técnicas de masaje sobre modelos sin violar políticas.</span>
              <select id="kc_pacientes_real" name="pacientes_real" class="kc-fld" required disabled={isLocked}>
                <option value="">Seleccione una opción...</option>
                <option value="reales_firma" selected={v('pacientes_real')==='reales_firma'}>Tenemos pacientes reales dispuestos a firmar cesión de derechos.</option>
                <option value="actores" selected={v('pacientes_real')==='actores'}>Podemos conseguir 2-3 modelos/actores para el día de rodaje.</option>
                <option value="solo_manos" selected={v('pacientes_real')==='solo_manos'}>Solo podemos grabar las manos del fisioterapeuta trabajando (sin rostros).</option>
                <option value="dificil" selected={v('pacientes_real')==='dificil'}>Es muy difícil, preferimos que el fisioterapeuta hable directo a cámara.</option>
              </select>
            </div>
          </div>
        </div>
      </section>

      <section class="kc-sec" style="--kc-accent:var(--kc-orange)">
        <div class="kc-sec-tile kc-t-orange">
          <div class="kc-left"><div class="kc-no">/ 02 — el gancho</div><div class="kc-ttl">La Oferta<br/>de Entrada</div></div>
          <div class="kc-meta">Gancho para Paid Media</div>
        </div>
        <div class="kc-sec-body">
          <div class="kc-card">
            <div class="kc-qg">
              <label class="kc-qlab">Para el video semanal de <strong>Paid Media (Anuncios)</strong>, necesitamos una "Oferta de Entrada" que rompa la fricción para el Avatar A (Hijos) y Avatar B (Profesionales). ¿Cuál de estas está dispuesto a promover?</label>
              <span class="kc-why"><strong>Por qué lo preguntamos:</strong> Un anuncio que solo dice "Agenda tu cita" tiene un CPL (Costo por Lead) alto. Un anuncio que ofrece una "Evaluación de Movilidad" o un "Combo de Descarga" genera un 40% más de clics a WhatsApp.</span>
              <div class="kc-opts">
                <label class="kc-opt"><input type="radio" name="offer" value="eval_movilidad" required checked={isChecked('offer','eval_movilidad')} disabled={isLocked} /><div><div class="kc-ot-t"><strong>Evaluación de Movilidad / Postura (Precio especial o incluida en 1ra sesión)</strong></div><div class="kc-ot-d">Ideal para Avatar A (Padres) y Deportistas. Permite al fisio hacer un "diagnóstico" visual en video.</div></div></label>
                <label class="kc-opt"><input type="radio" name="offer" value="combo_descarga" checked={isChecked('offer','combo_descarga')} disabled={isLocked} /><div><div class="kc-ot-t"><strong>Combo "Descarga Clínica": Masaje Terapéutico + 15 min Photon</strong></div><div class="kc-ot-d">Ideal para Avatar B (Profesionales estresados). Ataca el dolor inmediato y el deseo de relajación.</div></div></label>
                <label class="kc-opt"><input type="radio" name="offer" value="auditoria" checked={isChecked('offer','auditoria')} disabled={isLocked} /><div><div class="kc-ot-t"><strong>Auditoría de Ergonomía / Revisión de Pisada (Gratis con cita)</strong></div><div class="kc-ot-d">Un "Lead Magnet" de alto valor percibido que no devalúa el servicio médico.</div></div></label>
                <label class="kc-opt"><input type="radio" name="offer" value="ninguna" checked={isChecked('offer','ninguna')} disabled={isLocked} /><div><div class="kc-ot-t"><strong>Ninguna. Mantenemos el precio de lista y competimos solo por marca/autoridad.</strong></div><div class="kc-ot-d">Advertencia: Esto elevará el Costo por Adquisición (CPA) en Meta Ads significativamente.</div></div></label>
              </div>
              {(!isLocked || v('offer_other')) && (
                <div class="kc-other-wrap">
                  <label class="kc-other-lbl" for="kc_offer_other"><span>+</span> Otro / Especificar (opcional)</label>
                  <input type="text" id="kc_offer_other" name="offer_other" class="kc-fld" placeholder="Ej. Primera sesión a precio promocional, paquete de 5 sesiones, descuento para empresas..." value={v('offer_other') || ''} disabled={isLocked} />
                </div>
              )}
            </div>
            <div class="kc-qg">
              <label class="kc-qlab" for="kc_objecion_principal">Cuando un lead pregunta precios por WhatsApp y NO agenda, ¿cuál es la objeción #1 que recibe su equipo?</label>
              <span class="kc-why"><strong>Por qué lo preguntamos:</strong> Esto nos permitirá programar un "Script de Rebuttal" (Respuesta a objeción) en el flujo automatizado de WhatsApp para rescatar al 30% de los leads perdidos.</span>
              <input type="text" id="kc_objecion_principal" name="objecion_principal" class="kc-fld" required placeholder="Ej. 'Está muy caro comparado con el spa de la esquina', 'Me queda lejos', 'No tengo tiempo entre semana'..." value={v('objecion_principal') || ''} disabled={isLocked} />
            </div>
          </div>
        </div>
      </section>

      <section class="kc-sec" style="--kc-accent:var(--kc-lav)">
        <div class="kc-sec-tile kc-t-lav">
          <div class="kc-left"><div class="kc-no">/ 03 — ángulos</div><div class="kc-ttl">Estacionalidad<br/>y Ángulos</div></div>
          <div class="kc-meta">Ángulos de ataque</div>
        </div>
        <div class="kc-sec-body">
          <div class="kc-card">
            <div class="kc-grid kc-duo">
              <div class="kc-qg" style="margin-bottom:0">
                <label class="kc-qlab" for="kc_temporada">¿Hay algún evento local en CDMX o temporada en los próximos 6 meses (Mayo-Oct) que debamos atacar en los Hooks?</label>
                <span class="kc-why">Ej. Maratón CDMX, temporada de lluvias (caídas adultos mayores), Día del Padre/Madre, regreso a oficinas.</span>
                <textarea id="kc_temporada" name="temporada" class="kc-fld" placeholder="Ej. En Agosto muchos runners de la Condesa se lesionan preparándose para el Maratón..." disabled={isLocked}>{v('temporada') || ''}</textarea>
              </div>
              <div class="kc-qg" style="margin-bottom:0">
                <label class="kc-qlab" for="kc_competencia">Pensando en sus competidores locales (Physiosalud, Fisioliver), ¿cuál es su mayor debilidad según sus propios pacientes?</label>
                <span class="kc-why">Esto nos da el "Ángulo de Ataque" para los anuncios. Si ellos son lentos, nosotros vendemos "Agenda en 1 min por WA". Si son fríos, nosotros vendemos "Trato humano".</span>
                <textarea id="kc_competencia" name="competencia" class="kc-fld" placeholder="Ej. Son muy caros, nunca hay citas los sábados, o solo te ponen aparatos y el fisio no te toca..." disabled={isLocked}>{v('competencia') || ''}</textarea>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="kc-sec" style="--kc-accent:var(--kc-green)">
        <div class="kc-sec-tile kc-t-green">
          <div class="kc-left"><div class="kc-no">/ 04 — batching</div><div class="kc-ttl">Logística del<br/>Día de Rodaje</div></div>
          <div class="kc-meta">Batching</div>
        </div>
        <div class="kc-sec-body">
          <div class="kc-card">
            <div class="kc-qg">
              <label class="kc-qlab">Para grabar los 24 videos del Trimestre 1 en un solo bloque (Mes 2), necesitamos medio día de clínica "controlada". ¿Cuál es el mejor escenario?</label>
              <span class="kc-why"><strong>Por qué lo preguntamos:</strong> Grabar 24 reels de 30s toma unas 5-6 horas reales con cambios de luz, vestuario (bata vs. ropa deportiva) y setups de cámara.</span>
              <div class="kc-opts">
                <label class="kc-opt"><input type="radio" name="rodaje" value="domingo" required checked={isChecked('rodaje','domingo')} disabled={isLocked} /><div class="kc-ot-t"><strong>Domingo o Día inhábil:</strong> Pagamos horas extra al equipo, pero no interrumpimos pacientes.</div></label>
                <label class="kc-opt"><input type="radio" name="rodaje" value="viernes_tarde" checked={isChecked('rodaje','viernes_tarde')} disabled={isLocked} /><div class="kc-ot-t"><strong>Viernes por la tarde:</strong> Bloqueamos las últimas 4 horas de la clínica para grabar.</div></label>
                <label class="kc-opt"><input type="radio" name="rodaje" value="pacientes_reales" checked={isChecked('rodaje','pacientes_reales')} disabled={isLocked} /><div class="kc-ot-t"><strong>Durante pacientes reales:</strong> Grabamos "sobre la marcha" (B-Roll real), pero sacrificamos control de audio/luz.</div></label>
              </div>
              {(!isLocked || v('rodaje_other')) && (
                <div class="kc-other-wrap">
                  <label class="kc-other-lbl" for="kc_rodaje_other"><span>+</span> Otro / Especificar (opcional)</label>
                  <input type="text" id="kc_rodaje_other" name="rodaje_other" class="kc-fld" placeholder="Ej. Sábado por la mañana antes de abrir, dos sesiones más cortas en lugar de un bloque..." value={v('rodaje_other') || ''} disabled={isLocked} />
                </div>
              )}
            </div>
            <div class="kc-qg">
              <label class="kc-qlab" for="kc_vestuario">¿Qué vestuario tiene disponible el equipo para los videos? (El algoritmo favorece la autoridad visual)</label>
              <span class="kc-why">Los estudios demuestran que la bata clínica blanca o el uniforme médico (scrubs) aumentan la retención en un 22% vs. ropa de calle.</span>
              <select id="kc_vestuario" name="vestuario" class="kc-fld" required disabled={isLocked}>
                <option value="">Seleccione...</option>
                <option value="bata" selected={v('vestuario')==='bata'}>Bata clínica blanca impecable + Logo bordado.</option>
                <option value="scrubs" selected={v('vestuario')==='scrubs'}>Uniformo médico (Scrubs) con colores de la marca (Teal/Cyan).</option>
                <option value="polo" selected={v('vestuario')==='polo'}>Polo/Polo shirt con logo (Estilo más "Wellness/Deportivo").</option>
                <option value="mezcla" selected={v('vestuario')==='mezcla'}>Tenemos mezcla de Bata (para autoridad) y Ropa Deportiva (para masaje/rehab).</option>
              </select>
            </div>
          </div>
        </div>
      </section>

      {!isLocked && (
        <button type="submit" class="kc-btn" id="kc-submit">🚀 Validar Assets y Desbloquear Producción</button>
      )}
      <div class="kc-error" id="kc-error"></div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById('kc-form') as HTMLFormElement | null;
  if (form && form.dataset.locked !== '1') {
    const btn = document.getElementById('kc-submit') as HTMLButtonElement | null;
    const err = document.getElementById('kc-error') as HTMLDivElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn || !err) return;
      err.style.display = 'none';
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = 'Procesando Brief...';

      const fd = new FormData(form);
      const answers: Record<string, any> = {
        broll: fd.getAll('broll').map(String),
        broll_other: String(fd.get('broll_other') || '').trim(),
        pacientes_real: String(fd.get('pacientes_real') || ''),
        offer: String(fd.get('offer') || ''),
        offer_other: String(fd.get('offer_other') || '').trim(),
        objecion_principal: String(fd.get('objecion_principal') || ''),
        temporada: String(fd.get('temporada') || ''),
        competencia: String(fd.get('competencia') || ''),
        rodaje: String(fd.get('rodaje') || ''),
        rodaje_other: String(fd.get('rodaje_other') || '').trim(),
        vestuario: String(fd.get('vestuario') || ''),
      };

      try {
        const res = await fetch('/api/brief/questionnaire', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: form.dataset.token, type: 'kinecenter', answers }),
        });
        if (!res.ok) {
          const txt = await res.text();
          throw new Error(txt || `HTTP ${res.status}`);
        }
        // Reload to render the locked/answered state
        window.location.reload();
      } catch (e: any) {
        err.textContent = 'Error al guardar: ' + (e?.message || 'desconocido');
        err.style.display = 'block';
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  }
</script>
