---
// WorkList.astro — renders a list of works as links / embeds / placeholders
import Icon from './Icon.astro';
const { works = [] } = Astro.props;

// YouTube embeds render as a click-to-load facade (thumbnail + play button)
// so the heavy player JS only loads when a visitor actually presses play.
function videoInfo(url: string) {
  const yt = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]{11})/);
  if (yt) return {
    kind: 'youtube',
    id: yt[1],
    thumb: `https://i.ytimg.com/vi/${yt[1]}/hqdefault.jpg`,
    embed: `https://www.youtube-nocookie.com/embed/${yt[1]}?autoplay=1`,
  };
  const vim = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vim) return { kind: 'iframe', embed: `https://player.vimeo.com/video/${vim[1]}` };
  return { kind: 'video', embed: url };
}
---

<div class="work-links">
  {works.map((w: any) => {
    if (!w.url) {
      return (
        <span class="work-link is-empty">{w.label}<span class="wl-tag">soon</span></span>
      );
    }
    if (w.type === 'video') {
      const v = videoInfo(w.url);
      return (
        <div class="work-media">
          <span class="wm-label">{w.label}</span>
          <div class="work-embed">
            {v.kind === 'youtube'
              ? <button type="button" class="yt-facade" data-embed={v.embed} data-title={w.label}>
                  <img src={v.thumb} alt="" loading="lazy" decoding="async" width="480" height="360" />
                  <span class="yt-play"><Icon name="play" class="yt-play-ico" /></span>
                  <span class="sr-only">Play: {w.label}</span>
                </button>
              : v.kind === 'iframe'
                ? <iframe src={v.embed} loading="lazy" title={w.label} allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
                : <video src={v.embed} controls preload="metadata"></video>}
          </div>
        </div>
      );
    }
    if (w.type === 'audio') {
      return (
        <div class="work-audio">
          <span class="wa-label">{w.label}</span>
          <audio src={w.url} controls preload="none"></audio>
        </div>
      );
    }
    return (
      <a class="work-link" href={w.url} target="_blank" rel="noopener noreferrer">{w.label}<Icon name="arrow" class="wl-arrow" /></a>
    );
  })}
</div>

<script>
  // Click-to-load YouTube: swap the facade for the real player on demand.
  // stopPropagation keeps media clicks from bubbling to the card's
  // expand/collapse handler (same reason links are excluded there).
  document.querySelectorAll<HTMLButtonElement>('.yt-facade').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const iframe = document.createElement('iframe');
      iframe.src = btn.dataset.embed || '';
      iframe.title = btn.dataset.title || 'Video';
      iframe.setAttribute('allow', 'autoplay; fullscreen; picture-in-picture');
      iframe.setAttribute('allowfullscreen', '');
      btn.replaceWith(iframe);
    });
  });

  document.querySelectorAll<HTMLElement>('.work-embed, .work-audio').forEach((el) => {
    el.addEventListener('click', (e) => e.stopPropagation());
  });
</script>
