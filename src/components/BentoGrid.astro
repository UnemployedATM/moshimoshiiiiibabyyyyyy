---
// BentoGrid.astro — Bento portfolio with flippable client cards
// CV data from Pablo_J_Michel_CV_2026.docx on each card's back face
---

<div class="hero" aria-hidden="false">
  <div class="bento-grid">

    <!-- ================================================ -->
    <!-- AGENTS — Kaiba Digital (AI System Design)        -->
    <!-- ================================================ -->
    <div class="bento-card search-card expand-card" data-expand="search">
      <div class="card-inner">
        <div class="card-front agents-front">
          <span class="expand-hint" aria-hidden="true"></span>
          <div class="tab-label">AGENTS</div>
        </div>
        <div class="card-back">
          <button class="expand-close" aria-label="Flip back">&larr;</button>
          <div class="back-content split-layout wide-content">
            <div class="split-col">
              <span class="back-badge agents-accent">2023 &ndash; Present</span>
              <h3 class="back-company">Kaiba Digital</h3>
              <p class="back-role">AI System Designer</p>
              <span class="back-meta">Mexico</span>
              <div class="back-divider"></div>
              <p class="back-desc" style="margin-top: auto;">AI-assisted production pipelines, brand systems, and content workflows. Local LLM deployments and automation tooling for creative teams.</p>
            </div>
            <div class="split-col">
              <h3 class="back-company">Tech Stack</h3>
              <p class="back-role">Local &amp; Cloud LLM Tooling</p>
              <div class="back-divider"></div>
              <div class="back-tags">
                <span class="back-tag">Ollama</span>
                <span class="back-tag">n8n</span>
                <span class="back-tag">Open WebUI</span>
                <span class="back-tag">Prompt Eng.</span>
                <span class="back-tag">LLM Pipelines</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ================================================ -->
    <!-- BRIEFS — Client Token Access Form                -->
    <!-- ================================================ -->
    <div class="bento-card portfolios-card expand-card" data-expand="portfolios">
      <div class="card-inner">
        <div class="card-front brand-front">
          <span class="expand-hint" aria-hidden="true"></span>
          <div class="tab-label">BRIEFS</div>
        </div>
        <div class="card-back">
          <button class="expand-close" aria-label="Flip back">&larr;</button>
          <div class="back-content compact centered" style="text-align: center; justify-content: center; align-items: center;">
            <h3 class="back-company" style="margin-bottom: 1.5cqw; font-size: 5cqw;">Client Access</h3>
            <p class="back-desc" style="margin-bottom: 4cqw; font-size: 2.2cqw; color: #aaa;">Enter your unique token to securely view your project brief.</p>
            
            <form class="token-form" style="display: flex; flex-direction: column; gap: 2cqw; width: 100%; max-width: 300px; align-items: center;">
              <input 
                type="text" 
                class="brief-token-input"
                placeholder="Enter token..." 
                required 
                style="width: 100%; padding: 2.5cqw; border-radius: 1.5cqw; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); color: #fff; font-size: 2.8cqw; outline: none; text-align: center; font-family: 'Avenir Next', sans-serif; box-sizing: border-box;"
              />
              <button 
                type="submit" 
                style="padding: 2cqw 5cqw; background: #FF4B2B; color: #fff; border: none; border-radius: 1.2cqw; font-size: 2.5cqw; font-weight: 700; cursor: pointer; transition: transform 0.2s, filter 0.2s; font-family: 'Avenir Next', sans-serif;"
                onmouseover="this.style.transform='scale(1.05)'; this.style.filter='brightness(1.1)'"
                onmouseout="this.style.transform='scale(1)'; this.style.filter='brightness(1)'"
              >
                Access Brief
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

