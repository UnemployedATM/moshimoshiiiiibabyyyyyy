---
// BentoGrid.astro — Bento portfolio with flippable client cards
// CV data from Pablo_J_Michel_CV_2026.docx on each card's back face
import WorkList from './WorkList.astro';
import Icon from './Icon.astro';

// ─────────────────────────────────────────────────────────────
// CLIENT WORKS  →  edit here to add real links / material
// Each work: { label, url, type? }
//   • type omitted / 'link' → clickable link (opens new tab)
//   • type: 'video'         → embedded player (YouTube / Vimeo / .mp4 file)
//   • type: 'audio'         → embedded <audio> player (.mp3 / .wav file)
//   • url: '' (empty)       → muted "soon" chip (placeholder)
// Set  nda: true  on a client to show a protected notice instead of works.
// ─────────────────────────────────────────────────────────────
const videoWorks = [
  {
    id: 'ozone', name: 'Ozone Media', meta: '2024 – Present', color: '#00B4DB',
    works: [
      { label: 'Selected work', url: '' },
    ],
  },
  {
    id: 'quillcut', name: 'QuillCut Media', meta: '2024 – Present', color: '#00B4DB',
    nda: true, works: [],
  },
];

const audioWorks = [
  {
    id: 'radio-ibero', name: 'Radio Ibero', meta: 'Soundscape film · 2023', color: '#00D287',
    works: [
      { label: 'Domingo Familiar — soundscape film', url: '/media/radio-ibero-domingo-familiar.mp4', type: 'video', poster: '/media/radio-ibero-domingo-familiar.jpg' },
    ],
  },
  {
    id: 'other-audio', name: 'Other Audio Works', meta: 'Mixing · Sound design', color: '#00D287',
    works: [
      { label: 'Sound design & mix selects', url: '/media/audio-works-sample.mp4', type: 'video', poster: '/media/audio-works-sample.jpg' },
    ],
  },
];

// Dai Blue — both disciplines
const daiBlue = {
  id: 'dai-blue', name: 'Dai Blue', meta: 'Video + Audio · 2023 – Present',
  video: [
    { label: 'Editing & music', url: 'https://www.youtube.com/watch?v=fZxcnIMjUG4', type: 'video' },
    { label: '2D compositing', url: 'https://www.youtube.com/watch?v=rA16NzL8mH8&t=1s', type: 'video' },
  ],
  audio: [
    { label: 'Music composer', url: 'https://www.youtube.com/watch?v=NImKXJeqCKw', type: 'video' },
  ],
};

// Single-discipline clients share one detail template
const singleClients = [...videoWorks, ...audioWorks];
