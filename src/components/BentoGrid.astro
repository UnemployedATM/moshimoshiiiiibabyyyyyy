<script>
  // Flip-card interaction: click to flip, only one open at a time,
  // Escape to close, links pass through without flipping.

  const flipCards = document.querySelectorAll<HTMLElement>('.flip-card');

  flipCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Let real links work without flipping
      if (target.closest('a')) return;

      // Close button — unflip this card only
      if (target.closest('.flip-close')) {
        card.classList.remove('is-flipped');
        return;
      }

      // Unflip every other card first
      flipCards.forEach(c => {
        if (c !== card) c.classList.remove('is-flipped');
      });

      // Toggle this card
      card.classList.toggle('is-flipped');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      flipCards.forEach(c => c.classList.remove('is-flipped'));
    }
  });
</script>

