<script>
  const grid = document.querySelector('.bento-grid');
  const expandCards = document.querySelectorAll<HTMLElement>('.expand-card');

  expandCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      if (target.closest('a')) return;

      if (target.closest('.expand-close')) {
        card.classList.remove('is-expanded');
        if (grid) {
          const name = card.getAttribute('data-expand');
          if (name) grid.classList.remove('expand-' + name);
        }
        return;
      }

      // First close all other expanded cards
      expandCards.forEach(c => {
        if (c !== card) {
          c.classList.remove('is-expanded');
          if (grid) {
            const name = c.getAttribute('data-expand');
            if (name) grid.classList.remove('expand-' + name);
          }
        }
      });

      // Expand this card
      card.classList.add('is-expanded');
      if (grid) {
        const name = card.getAttribute('data-expand');
        if (name) grid.classList.add('expand-' + name);
      }
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      expandCards.forEach(card => {
        card.classList.remove('is-expanded');
        if (grid) {
          const name = card.getAttribute('data-expand');
          if (name) grid.classList.remove('expand-' + name);
        }
      });
    }
  });
</script>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { DRACOLoader } from 'three/addons/loaders/DRACOLoader.js';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

  const canvas = document.getElementById('head-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    
    // Set high-quality resolution
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    
    // Match Blender's Color Management system
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    // Adjust this in your renderer setup block
    renderer.toneMappingExposure = 1.4; // Boosted from 1.0 to brighten up everything safely
    
    // Turn on the shadow engine
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    
    // ==========================================================
    // 🛠️ BLENDER PERSPECTIVE CAMERA SETTINGS 🛠️
    // Modify blenderFocalLength to match your Blender setup
    // ==========================================================
    let blenderFocalLength = 1000; // Change this to your exact Blender focal length
    const blenderSensorWidth = 36; // Blender's default "Full Frame" sensor width
    
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
    camera.position.set(0, 0, 40); // Modify Z to push the camera in/out
    camera.lookAt(0, 0, 0);

    function matchBlenderCamera(aspect) {
      // 1. Calculate Blender's horizontal FOV in radians
      const horizontalFOV = 2 * Math.atan(blenderSensorWidth / (2 * blenderFocalLength));
      // 2. Convert horizontal FOV to Three.js vertical FOV in degrees
      const verticalFOV = 2 * Math.atan(Math.tan(horizontalFOV / 2) / aspect) * (180 / Math.PI);
      
      camera.fov = verticalFOV;
      camera.aspect = aspect;
      camera.updateProjectionMatrix();
    }

    const updateSize = () => {
      const container = canvas.parentElement;
      if (!container) return;
      const width = container.clientWidth;
      const height = container.clientHeight;
      
      if (width === 0 || height === 0) return;
      
      // false so the canvas CSS width/height remains 100%
      renderer.setSize(width, height, false);
      
      const aspect = width / height;
      matchBlenderCamera(aspect);

      // Prevent the head from touching the corners (Acts like object-fit: contain)
      if (headWrapper && headWrapper.userData.baseScale) {
        // If the box is wider than it is tall, the fixed horizontal FOV will cause 
        // the head to expand and clip the top/bottom. We scale it down to compensate.
        const aspectAdjust = aspect > 1 ? (1 / aspect) : 1;
        // 0.8 acts as a safe padding margin so it never touches the edges
        headWrapper.scale.setScalar(headWrapper.userData.baseScale * aspectAdjust * 0.8);
      }
      
      // Force an immediate render to prevent flickering/stretching during layout shifts
      renderer.render(scene, camera);
    };

    // Remove OrbitControls entirely so we have manual control
    // const controls = new OrbitControls(camera, renderer.domElement);

    // 1. Ambient Light to fill dark voids
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
    scene.add(ambientLight);

    // 2. Main Key Light (placed diagonally in front, above the head)
    const mainLight = new THREE.DirectionalLight(0xffffff, 0.8);
    mainLight.position.set(5, 8, 5); 
    mainLight.castShadow = true;

    // 3. Fine-tune shadow quality
    mainLight.shadow.mapSize.width = 2048; // High resolution shadows
    mainLight.shadow.mapSize.height = 2048;
    mainLight.shadow.bias = -0.0005; // Fixes tiny shadow gaps
    mainLight.shadow.camera.near = 0.5;
    mainLight.shadow.camera.far = 25;
    scene.add(mainLight);

    const dracoLoader = new DRACOLoader();
    dracoLoader.setDecoderPath('https://unpkg.com/three@0.184.0/examples/jsm/libs/draco/gltf/');

    const loader = new GLTFLoader();
    loader.setDRACOLoader(dracoLoader);
    
    let headWrapper = new THREE.Group();
    scene.add(headWrapper);

    loader.load('/models/Head4.glb', (gltf) => {
      const model = gltf.scene;
      
      // Traverse the 3D model data tree to enable shadows and tweak materials
      model.traverse((node) => {
          if (node.isMesh) {
              node.castShadow = true;     
              node.receiveShadow = true;  
              
              // Force smooth shading across the face mesh
              node.geometry.computeVertexNormals();
              
              // If skin looks too shiny, make it matte like Blender
              if (node.material) {
                  node.material.roughness = 0.7; // Make it matte like clay
                  node.material.metalness = 0.0; // Keep it non-reflective
              }
          }
      });
      
      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      const size = box.getSize(new THREE.Vector3());
      
      const maxDim = Math.max(size.x, size.y, size.z);
      // Base scale (we use 1.4 as the baseline fitting size)
      const baseScale = 1.4 / (maxDim || 1); 
      headWrapper.userData.baseScale = baseScale;
      
      // Center the model properly
      model.position.x = -center.x;
      model.position.y = -center.y;
      model.position.z = -center.z;
      
      headWrapper.add(model);
      
      // Force an immediate size update now that baseScale is known
      updateSize(); 
    });

    // Initial call before model loads just to set canvas sizes
    updateSize();

    const resizeObserver = new ResizeObserver(() => updateSize());
    if (canvas.parentElement) {
      resizeObserver.observe(canvas.parentElement);
    }

    // Look and snap logic
    let targetRotationX = 0;
    let targetRotationY = 0;
    
    const cards = document.querySelectorAll('.bento-card');
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        if (card.id === 'head-card') {
          targetRotationX = 0;
          targetRotationY = 0;
        } else {
          const headRect = canvas.parentElement!.getBoundingClientRect();
          const cardRect = card.getBoundingClientRect();
          
          const headCenterX = headRect.left + headRect.width / 2;
          const headCenterY = headRect.top + headRect.height / 2;
          
          const cardCenterX = cardRect.left + cardRect.width / 2;
          const cardCenterY = cardRect.top + cardRect.height / 2;
          
          const dx = cardCenterX - headCenterX;
          const dy = cardCenterY - headCenterY;
          
          // Both axes should directly map to dx/dy to look AT the target
          let rawY = (dx / window.innerWidth) * 1.2; 
          let rawX = (dy / window.innerHeight) * 1.2;
          
          // Clamp the rotation so it doesn't turn too far (limit amount of X/Y movement)
          const maxTurn = 0.5; // approx 35 degrees limit
          targetRotationY = Math.max(-maxTurn, Math.min(maxTurn, rawY));
          targetRotationX = Math.max(-maxTurn, Math.min(maxTurn, rawX));
        }
      });
    });

    const animate = () => {
      requestAnimationFrame(animate);
      
      // Much smoother snap interpolation (lowered from 0.15 to 0.06)
      if (headWrapper) {
        headWrapper.rotation.x += (targetRotationX - headWrapper.rotation.x) * 0.04;
        headWrapper.rotation.y += (targetRotationY - headWrapper.rotation.y) * 0.04;
      }
      
      renderer.render(scene, camera);
    };
    animate();
  }

  // Token Form Logic
  const tokenForm = document.querySelector('.token-form');
  if (tokenForm) {
    tokenForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.querySelector('.brief-token-input');
      const token = input.value.trim().toLowerCase();
      if (token) {
        window.location.href = `/briefs/${token}`;
      }
    });
  }
</script>

