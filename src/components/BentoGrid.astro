<script>
  const grid = document.querySelector('.bento-grid');
  const expandCards = document.querySelectorAll<HTMLElement>('.expand-card');

  const collapse = (card: HTMLElement) => {
    card.classList.remove('is-expanded');
    card.setAttribute('aria-expanded', 'false');
    if (grid) {
      const name = card.getAttribute('data-expand');
      if (name) grid.classList.remove('expand-' + name);
    }
  };

  expandCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      if (target.closest('a') || target.closest('input') || target.closest('button[type="submit"]')) return;

      // If this card is already expanded, close it (toggle)
      if (card.classList.contains('is-expanded')) {
        collapse(card);
        return;
      }

      // First close all other expanded cards
      expandCards.forEach(c => { if (c !== card) collapse(c); });

      // Expand this card
      card.classList.add('is-expanded');
      card.setAttribute('aria-expanded', 'true');
      if (grid) {
        const name = card.getAttribute('data-expand');
        if (name) grid.classList.add('expand-' + name);
      }
    });

    // Keyboard: Enter/Space toggles through the exact same click path
    card.addEventListener('keydown', (e) => {
      if ((e.key === 'Enter' || e.key === ' ') && e.target === card) {
        e.preventDefault();
        card.click();
      }
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      expandCards.forEach(card => {
        const wasExpanded = card.classList.contains('is-expanded');
        collapse(card);
        // Return focus to the card so keyboard users aren't dropped to <body>
        if (wasExpanded) card.focus({ preventScroll: true });
      });
    }
  });

  // ── EDITOR card: client → works navigation ──────────────────
  const editorCard = document.querySelector<HTMLElement>('[data-expand="dashboard"]');
  if (editorCard) {
    const listView = editorCard.querySelector<HTMLElement>('[data-view="list"]');
    const detailViews = editorCard.querySelectorAll<HTMLElement>('.works-detail');
    let lastOpener: HTMLElement | null = null;

    const showList = () => {
      detailViews.forEach(d => { d.hidden = true; });
      if (listView) listView.hidden = false;
    };
    const showDetail = (id: string | null) => {
      if (listView) listView.hidden = true;
      detailViews.forEach(d => { d.hidden = d.getAttribute('data-detail') !== id; });
    };

    editorCard.querySelectorAll<HTMLElement>('.client-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        lastOpener = btn;
        const id = btn.getAttribute('data-open');
        showDetail(id);
        // Announce the view change and keep focus in a sensible place
        const title = editorCard.querySelector<HTMLElement>(`[data-detail="${id}"] .detail-title`);
        if (title) title.focus({ preventScroll: true });
      });
    });
    editorCard.querySelectorAll<HTMLElement>('.works-back').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        showList();
        if (lastOpener) lastOpener.focus({ preventScroll: true });
      });
    });

    // Always return to the list when the card collapses
    const obs = new MutationObserver(() => {
      if (!editorCard.classList.contains('is-expanded')) showList();
    });
    obs.observe(editorCard, { attributes: true, attributeFilter: ['class'] });
  }
</script>

<script>
  // 3D head — three.js is imported lazily once the browser is idle so the
  // library never blocks first paint. The flat poster silhouette covers the
  // card until the model is ready, and stays if loading fails.
  const headCanvas = document.getElementById('head-canvas') as HTMLCanvasElement | null;

  async function initHead(canvas: HTMLCanvasElement) {
    const THREE = await import('three');
    const [{ GLTFLoader }, { DRACOLoader }] = await Promise.all([
      import('three/addons/loaders/GLTFLoader.js'),
      import('three/addons/loaders/DRACOLoader.js'),
    ]);

    const poster = canvas.parentElement?.querySelector('.head-poster');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const mobileMq = window.matchMedia('(max-width: 768px)');

    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });

    // Set high-quality resolution
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Match Blender's Color Management system
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.4; // Boosted from 1.0 to brighten up everything safely

    // Turn on the shadow engine
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    // Blender perspective camera settings — blenderFocalLength must match
    // the Blender camera used to frame the model
    const blenderFocalLength = 1000;
    const blenderSensorWidth = 36; // Blender's default "Full Frame" sensor width

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 1000);
    camera.position.set(0, 0, 40); // Modify Z to push the camera in/out
    camera.lookAt(0, 0, 0);

    function matchBlenderCamera(aspect: number) {
      // Blender's horizontal FOV, converted to Three.js vertical FOV
      const horizontalFOV = 2 * Math.atan(blenderSensorWidth / (2 * blenderFocalLength));
      const verticalFOV = 2 * Math.atan(Math.tan(horizontalFOV / 2) / aspect) * (180 / Math.PI);

      camera.fov = verticalFOV;
      camera.aspect = aspect;
      camera.updateProjectionMatrix();
    }

    const updateSize = () => {
      const container = canvas.parentElement;
      if (!container) return;
      const width = container.clientWidth;
      const height = container.clientHeight;

      if (width === 0 || height === 0) return;

      // false so the canvas CSS width/height remains 100%
      renderer.setSize(width, height, false);

      const aspect = width / height;
      matchBlenderCamera(aspect);

      // Prevent the head from touching the corners (Acts like object-fit: contain)
      if (headWrapper && headWrapper.userData.baseScale) {
        // If the box is wider than it is tall, the fixed horizontal FOV will cause
        // the head to expand and clip the top/bottom. We scale it down to compensate.
        const aspectAdjust = aspect > 1 ? (1 / aspect) : 1;
        // 0.8 acts as a safe padding margin so it never touches the edges
        headWrapper.scale.setScalar(headWrapper.userData.baseScale * aspectAdjust * 0.8);
      }

      // Force an immediate render to prevent flickering/stretching during layout shifts
      renderer.render(scene, camera);
    };

    // 1. Ambient Light to fill dark voids
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
    scene.add(ambientLight);

    // 2. Main Key Light (placed diagonally in front, above the head)
    const mainLight = new THREE.DirectionalLight(0xffffff, 0.8);
    mainLight.position.set(5, 8, 5);
    mainLight.castShadow = true;

    // 3. Fine-tune shadow quality
    mainLight.shadow.mapSize.width = 2048; // High resolution shadows
    mainLight.shadow.mapSize.height = 2048;
    mainLight.shadow.bias = -0.0005; // Fixes tiny shadow gaps
    mainLight.shadow.camera.near = 0.5;
    mainLight.shadow.camera.far = 25;
    scene.add(mainLight);

    const dracoLoader = new DRACOLoader();
    // Decoder ships with the site (public/draco/) — no third-party request
    dracoLoader.setDecoderPath('/draco/');

    const loader = new GLTFLoader();
    loader.setDRACOLoader(dracoLoader);

    let headWrapper = new THREE.Group();
    scene.add(headWrapper);

    loader.load('/models/Head4.glb', (gltf) => {
      const model = gltf.scene;

      // Traverse the 3D model data tree to enable shadows and tweak materials
      model.traverse((node) => {
          if (node.isMesh) {
              node.castShadow = true;
              node.receiveShadow = true;

              // Force smooth shading across the face mesh
              node.geometry.computeVertexNormals();

              // If skin looks too shiny, make it matte like Blender
              if (node.material) {
                  node.material.roughness = 0.7; // Make it matte like clay
                  node.material.metalness = 0.0; // Keep it non-reflective
              }
          }
      });

      const box = new THREE.Box3().setFromObject(model);
      const center = box.getCenter(new THREE.Vector3());
      const size = box.getSize(new THREE.Vector3());

      const maxDim = Math.max(size.x, size.y, size.z);
      // Base scale (we use 1.4 as the baseline fitting size)
      const baseScale = 1.4 / (maxDim || 1);
      headWrapper.userData.baseScale = baseScale;

      // Center the model properly
      model.position.x = -center.x;
      model.position.y = -center.y;
      model.position.z = -center.z;

      headWrapper.add(model);

      // Model is live — fade the poster out
      if (poster) poster.classList.add('is-hidden');

      // Force an immediate size update now that baseScale is known
      updateSize();
    }, undefined, () => {
      // Load failed — leave the poster in place so the card never looks broken
    });

    // Initial call before model loads just to set canvas sizes
    updateSize();

    const resizeObserver = new ResizeObserver(() => updateSize());
    if (canvas.parentElement) {
      resizeObserver.observe(canvas.parentElement);
    }

    // Look-at targets (only used in desktop mode; touch devices don't fire mouseenter)
    let targetRotationX = 0;
    let targetRotationY = 0;

    document.querySelectorAll('.bento-card').forEach(card => {
      card.addEventListener('mouseenter', () => {
        if (card.id === 'head-card') {
          targetRotationX = 0;
          targetRotationY = 0;
        } else {
          const headRect = canvas.parentElement!.getBoundingClientRect();
          const cardRect = card.getBoundingClientRect();

          const headCenterX = headRect.left + headRect.width / 2;
          const headCenterY = headRect.top + headRect.height / 2;

          const cardCenterX = cardRect.left + cardRect.width / 2;
          const cardCenterY = cardRect.top + cardRect.height / 2;

          const dx = cardCenterX - headCenterX;
          const dy = cardCenterY - headCenterY;

          let rawY = (dx / window.innerWidth) * 1.2;
          let rawX = (dy / window.innerHeight) * 1.2;

          const maxTurn = 0.5;
          targetRotationY = Math.max(-maxTurn, Math.min(maxTurn, rawY));
          targetRotationX = Math.max(-maxTurn, Math.min(maxTurn, rawX));
        }
      });
    });

    let last = performance.now();
    const animate = (now: number) => {
      requestAnimationFrame(animate);

      const dt = Math.min((now - last) / 1000, 0.1);
      last = now;

      // Skip rendering while the card is display:none (e.g. mobile expanded state)
      if (canvas.getClientRects().length === 0) return;

      if (headWrapper) {
        if (mobileMq.matches) {
          // Slow continuous spin — 0.3 rad/s == the original 0.005/frame at
          // 60fps, now identical on 120Hz screens. Paused for reduced motion.
          if (!reduceMotion.matches) headWrapper.rotation.y += 0.3 * dt;
        } else if (reduceMotion.matches) {
          // Reduced motion: same look-at pose, without animated easing
          headWrapper.rotation.x = targetRotationX;
          headWrapper.rotation.y = targetRotationY;
        } else {
          // Smooth snap interpolation on desktop
          headWrapper.rotation.x += (targetRotationX - headWrapper.rotation.x) * 0.04;
          headWrapper.rotation.y += (targetRotationY - headWrapper.rotation.y) * 0.04;
        }
      }

      renderer.render(scene, camera);
    };
    requestAnimationFrame(animate);
  }

  if (headCanvas) {
    const startHead = () => { initHead(headCanvas); };
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(startHead, { timeout: 1500 });
    } else {
      setTimeout(startHead, 200);
    }
  }

  // Token Form Logic
  const tokenForm = document.querySelector('.token-form');
  if (tokenForm) {
    tokenForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = document.querySelector<HTMLInputElement>('.brief-token-input');
      const token = input ? input.value.trim().toLowerCase() : '';
      if (token) {
        window.location.href = `/briefs/${token}`;
      }
    });
  }
</script>

