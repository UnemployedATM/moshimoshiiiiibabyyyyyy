---
// Hero — bio block, inlined from Porfolio.svg with the <g id="Tabs"> group removed
// so the HTML tabs in Tabs.astro can take over. SVG is responsive to .stage size.
---
<div class="hero" aria-hidden="false">
  <svg
    viewBox="0 0 3508 2481"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label="Pablo Michel — Interfaces, and the intelligence within."
  >
    <g id="Intro--bio-">
      <g transform="matrix(0.288366,0,0,0.288366,1128.466887,896.558524)">
        <text
          x="135.358px"
          y="564px"
          style="font-family:'AvenirNext-Bold','Avenir Next',sans-serif;font-weight:700;font-size:674.29px;fill:#fff;"
        >/P<tspan x="815.042px 1196.691px" y="564px 564px">ab</tspan>lo</text>
        <text
          x="2268.138px"
          y="564px"
          style="font-family:'BigCaslon-Medium','Big Caslon',serif;font-weight:500;font-size:674.29px;fill:#fff;"
        >Michel</text>
      </g>
      <g transform="matrix(1,0,0,1,115.174125,-343.248811)">
        <text
          x="1054px"
          y="1537.8px"
          style="font-family:'AvenirNext-Regular','Avenir Next',sans-serif;font-size:50px;fill:#fff;"
        >Interfaces,</text>
        <text
          x="1302.642px"
          y="1537.8px"
          style="font-family:'BigCaslon-Medium','Big Caslon',serif;font-weight:500;font-size:50px;fill:#fff;"
        >&amp; the intelligence within.</text>

        <text
          x="1054px"
          y="1650.408px"
          style="font-family:'AvenirNext-Regular','Avenir Next',sans-serif;font-size:45.833px;fill:#fff;"
        >Working out of Mexico, fluent across LATAM and global</text>
        <text
          x="1054px"
          y="1713.017px"
          style="font-family:'AvenirNext-Regular','Avenir Next',sans-serif;font-size:45.833px;fill:#fff;"
        >English-speaking markets. I design end-to-end products;</text>
        <text
          x="1054px"
          y="1775.625px"
          style="font-family:'AvenirNext-Regular','Avenir Next',sans-serif;font-size:45.833px;fill:#fff;"
        >from user research to production code with AI tooling</text>
        <text
          x="1054px"
          y="1838.233px"
          style="font-family:'AvenirNext-Regular','Avenir Next',sans-serif;font-size:45.833px;fill:#fff;"
        >threading through every layer of the work. <tspan style="font-family:'AvenirNext-Italic','Avenir Next',sans-serif;font-style:italic;">Serial builder</tspan></text>
        <text
          x="1054px"
          y="1900.842px"
          style="font-family:'AvenirNext-Italic','Avenir Next',sans-serif;font-style:italic;font-size:45.833px;fill:#fff;"
        >of small, careful systems.</text>
      </g>
    </g>
  </svg>
</div>
