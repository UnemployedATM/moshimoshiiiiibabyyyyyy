---
// Icon.astro — flat, filled, monochrome icons (no strokes). Fill uses currentColor.
const { name, class: className = '' } = Astro.props;
const paths: Record<string, string> = {
  // solid right caret
  chevron: 'M9 6l6 6-6 6z',
  // solid left caret
  back: 'M15 6l-6 6 6 6z',
  // filled padlock
  lock: 'M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z',
  // filled up-right arrow
  arrow: 'M7 7v2h6.59L6 16.59 7.41 18 15 10.41V17h2V7z',
  // filled play triangle
  play: 'M8 5v14l11-7z',
};
---
<svg class={`ico ${className}`} viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d={paths[name]} /></svg>
