---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '/Pablo Michel — Portfolio' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Pablo Michel — Interfaces, and the intelligence within." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
