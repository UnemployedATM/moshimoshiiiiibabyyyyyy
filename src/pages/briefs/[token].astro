---
import { supabase } from '../../lib/supabase';

const { token } = Astro.params;

let client = null;

try {
  const { data, error } = await supabase
    .from('Client')
    .select('*')
    .ilike('token', token)
    .single();
    
  if (data) {
    client = data;
  }
} catch (error) {
  console.error("Database error:", error);
}

if (!client) {
  // Return a 404 response if token is invalid or DB fails
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

// Clean up HTML safely or trust the DB
const rawHtml = client.briefHtml;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{client.name} - Brief</title>
  <style is:global>
    body {
      margin: 0; padding: 0; background: #0d0d12; color: #fff; font-family: 'Avenir Next', system-ui, sans-serif;
      min-height: 100vh; display: flex; justify-content: center;
    }
    .brief-container {
      width: 100%; max-width: 1400px; padding: 40px 20px;
    }
    .top-bar {
      display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;
    }
    .back-btn { color: #888; text-decoration: none; font-weight: 500; }
    .back-btn:hover { color: #fff; }
    
    .print-btn {
      background: #FF4B2B; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: 600;
    }
    .print-btn:hover { filter: brightness(1.1); }
    
    .brief-content {
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 20px; line-height: 1.6;
    }

    /* Beautiful PDF Print Styles */
    @media print {
      body {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        background: #0d0d12 !important;
      }
      .top-bar { display: none !important; }
      
      .brief-content { 
        background: transparent !important; 
        border: none !important; 
        padding: 0 !important; 
        margin: 0 !important;
      }

      /* Prevent elements from breaking across pages */
      .brief-content > *,
      .brief-content div,
      .brief-content section,
      .brief-content article,
      .brief-content .card {
        break-inside: avoid !important;
        page-break-inside: avoid !important;
        overflow: visible !important;
      }

      /* === CHROMIUM FLEX/GRID PAGINATION BUG FIX === */
      /* Chrome cannot paginate inside flex/grid. We MUST convert to block/inline-block */
      .brief-content { display: block !important; }
      
      /* Target the user's custom layout classes */
      .bento, .grid4, .grid2 {
        display: block !important; /* Destroy flex/grid container */
      }

      /* Emulate grid columns using inline-block so they don't break */
      .grid4 > div, .grid2 > div {
        display: inline-block !important;
        width: 48% !important;
        vertical-align: top !important;
        box-sizing: border-box !important;
      }
      .grid4 > div:nth-child(even), .grid2 > div:nth-child(even) { margin-left: 2% !important; }

      .card {
        display: block !important; /* Destroy flex column */
        break-inside: avoid !important;
        page-break-inside: avoid !important;
      }

      /* Fix the 3-column strategy/totals cards */
      .card.strat, .card.tot {
        display: inline-block !important;
        width: 32% !important;
        margin-right: 1% !important;
        vertical-align: top !important;
        box-sizing: border-box !important;
      }
      
      /* Fix the notes split */
      .card.notes { display: inline-block !important; width: 60% !important; vertical-align: top !important; }
      .card.notes-side { display: inline-block !important; width: 38% !important; margin-left: 1% !important; vertical-align: top !important; }
      /* ============================================= */
      
      .brief-container {
        display: block !important;
        width: 816px !important; /* Exact width of Letter paper at 96dpi */
        max-width: 816px !important;
        padding: 40px !important; /* Add internal padding since page margins are 0 */
        margin: 0 auto !important;
        box-sizing: border-box !important;
      }

      h1, h2, h3 { page-break-after: avoid !important; }
      
      /* Force browser print settings to match user requirements */
      @page { 
        size: letter portrait;
        margin: 0;
      }
    }
  </style>
</head>
<body>
  <div class="brief-container">
    
    <div class="top-bar">
      <a href="/" class="back-btn">&larr; Back to Portfolio</a>
      <button class="print-btn" onclick="window.print()">Download as PDF</button>
    </div>

    <div class="brief-content" set:html={rawHtml}></div>

  </div>
</body>
</html>
