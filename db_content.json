[{"briefHtml":"<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Kinecenter MX · Brief + Presupuesto · bidaman, creative lab</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&family=Caveat:wght@500;600&display=swap\" rel=\"stylesheet\">\n<style>\n:root{\n  --bg:#000000;\n  --ink:#0e0f13;\n  --card:#16181f;\n  --card-2:#1d2029;\n  --card-3:#262a35;\n  --line:#2d3340;\n  --text:#f4f5f7;\n  --muted:#9aa1ad;\n  --faint:#6b7280;\n\n  --purple:#b794ff;\n  --green:#10d68a;\n  --pink:#ff1f7a;\n  --orange:#fc4c2e;\n  --cyan:#13b6e0;\n  --yellow:#ffc107;\n\n  --r:26px;\n  --gap:16px;\n}\n*{box-sizing:border-box;margin:0;padding:0}\nhtml{scroll-behavior:smooth}\nbody{\n  background:var(--bg);\n  color:var(--text);\n  font-family:\"DM Sans\",sans-serif;\n  line-height:1.55;\n  -webkit-font-smoothing:antialiased;\n  padding:clamp(14px,3vw,40px);\n}\n.wrap{max-width:1180px;margin:0 auto}\n\n/* generic */\n.serif{font-family:\"Fraunces\",serif}\n.hand{font-family:\"Caveat\",cursive}\n.slash{color:var(--purple)}\n.eyebrow{\n  font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;\n  font-weight:700;color:var(--faint);\n}\n.bento{display:grid;grid-template-columns:repeat(12,1fr);gap:var(--gap)}\n.card{\n  background:var(--card);border-radius:var(--r);\n  padding:clamp(22px,2.4vw,34px);position:relative;overflow:hidden;\n  opacity:0;transform:translateY(18px);\n  animation:rise .7s cubic-bezier(.2,.7,.2,1) forwards;\n}\n@keyframes rise{to{opacity:1;transform:none}}\n.card:nth-child(1){animation-delay:.02s}\n.card:nth-child(2){animation-delay:.08s}\n.card:nth-child(3){animation-delay:.14s}\n.card:nth-child(4){animation-delay:.2s}\n.card:nth-child(5){animation-delay:.26s}\n.card:nth-child(6){animation-delay:.32s}\n@media (prefers-reduced-motion:reduce){.card{animation:none;opacity:1;transform:none}}\n\n/* ===== HERO ===== */\n.hero{margin-bottom:var(--gap)}\n.h-left{grid-column:span 8;background:var(--ink);display:flex;flex-direction:column;justify-content:space-between;min-height:300px}\n.h-right{grid-column:span 4;display:flex;flex-direction:column;gap:var(--gap)}\n.brandmark{font-size:clamp(2rem,4.4vw,3.4rem);font-weight:600;letter-spacing:-.02em;line-height:1}\n.brandmark .lab{font-family:\"DM Sans\";font-weight:400;color:var(--muted);font-size:.42em;letter-spacing:.02em;display:block;margin-top:.5em}\n.h-title{font-size:clamp(1.5rem,2.6vw,2.1rem);font-weight:500;line-height:1.15;margin-top:auto}\n.h-title em{font-style:italic;color:var(--purple)}\n.chip{\n  align-self:flex-start;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;\n  font-weight:700;color:#000;background:var(--green);padding:6px 14px;border-radius:999px;margin-bottom:18px;\n}\n.h-card-pink{background:var(--pink);color:#fff;flex:1;display:flex;flex-direction:column;justify-content:center}\n.h-card-pink .big{font-size:2.6rem;font-weight:700;line-height:1;font-family:\"Fraunces\"}\n.h-card-pink .lbl{font-size:.85rem;opacity:.9;margin-top:6px}\n.h-card-dark{background:var(--card-2);flex:1}\n.h-card-dark .meta{font-size:.82rem;color:var(--muted)}\n.h-card-dark .meta b{color:var(--text)}\n\n/* section heading */\n.section-head{grid-column:span 12;display:flex;align-items:baseline;gap:16px;margin-top:30px;flex-wrap:wrap}\n.section-head h2{font-family:\"Fraunces\";font-weight:500;font-size:clamp(1.4rem,2.6vw,2rem);letter-spacing:-.01em}\n.section-head .num{font-family:\"Fraunces\";color:var(--purple);font-size:1.1rem;font-style:italic}\n.section-head p{color:var(--muted);font-size:.9rem;flex-basis:100%;max-width:62ch}\n\n/* snapshot row */\n.snap{grid-column:span 3}\n.snap.green{background:var(--green);color:#04150e}\n.snap.cyan{background:var(--cyan);color:#03222b}\n.snap.yellow{background:var(--yellow);color:#241c00}\n.snap.orange{background:var(--orange);color:#fff}\n.snap .n{font-family:\"Fraunces\";font-size:2.3rem;font-weight:600;line-height:1}\n.snap .k{font-size:.78rem;font-weight:600;margin-top:8px;opacity:.85;text-transform:uppercase;letter-spacing:.08em}\n.snap .sub{font-size:.8rem;margin-top:6px;opacity:.7;line-height:1.35}\n\n/* pain points */\n.pain{grid-column:span 6;background:var(--card)}\n.pain .tag{display:inline-block;font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--orange);margin-bottom:10px}\n.pain h3{font-size:1.05rem;font-weight:700;margin-bottom:8px}\n.pain p{color:var(--muted);font-size:.92rem}\n\n/* full width understanding */\n.full{grid-column:span 12;background:var(--card-2)}\n.full .grid2{display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-top:6px}\n.full ul{list-style:none}\n.full li{padding:9px 0;border-bottom:1px solid var(--line);font-size:.92rem;display:flex;gap:12px;align-items:flex-start}\n.full li:last-child{border-bottom:none}\n.full li .dot{color:var(--green);font-weight:700;flex-shrink:0}\n.full li b{color:var(--text)}\n.full li span{color:var(--muted)}\n.full .neg .dot{color:var(--pink)}\n\n/* strategy cards */\n.strat{grid-column:span 4;background:var(--card)}\n.strat .ic{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:\"Fraunces\";font-size:1.3rem;font-weight:600;margin-bottom:16px;color:#000}\n.strat h3{font-size:1.02rem;font-weight:700;margin-bottom:8px}\n.strat p{color:var(--muted);font-size:.9rem}\n\n/* ===== PANORAMA COMPETITIVO ===== */\n.comp-lead{grid-column:span 4;background:var(--cyan);color:#03222b;display:flex;flex-direction:column;justify-content:center}\n.comp-lead .eyebrow{color:#064a5c}\n.comp-lead h3{font-family:\"Fraunces\";font-size:1.5rem;font-weight:600;line-height:1.1;margin:8px 0}\n.comp-lead p{font-size:.86rem;opacity:.85}\n.comp-table{grid-column:span 8;background:var(--card);padding:0;overflow:hidden}\n.comp-table table{width:100%;border-collapse:collapse;font-size:.9rem}\n.comp-table thead th{text-align:left;padding:16px 20px;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--faint);font-weight:700;border-bottom:1px solid var(--line)}\n.comp-table tbody td{padding:15px 20px;border-bottom:1px solid var(--line);vertical-align:top}\n.comp-table tbody tr:last-child td{border-bottom:none}\n.comp-table tbody tr.ref td{background:rgba(183,148,255,.08)}\n.cl-name{font-weight:700}\n.cl-addr{display:block;color:var(--faint);font-size:.76rem;margin-top:2px}\n.stars{color:var(--yellow);letter-spacing:1px;white-space:nowrap;font-size:.92rem}\n.stars .off{color:var(--line)}\n.sim{display:inline-block;font-size:.66rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:3px 10px;border-radius:999px}\n.sim.high{background:rgba(16,214,138,.16);color:var(--green)}\n.sim.mid{background:rgba(255,193,7,.16);color:var(--yellow)}\n.sim.low{background:rgba(252,76,46,.16);color:var(--orange)}\n.sim.ref{background:rgba(183,148,255,.16);color:var(--purple)}\n.comp-detail{grid-column:span 6;background:var(--card)}\n.comp-detail h3{font-size:1rem;font-weight:700;margin-bottom:4px;display:flex;align-items:center;gap:10px}\n.comp-detail .rank{font-family:\"Fraunces\";color:var(--purple);font-style:italic;font-size:1.1rem}\n.comp-detail .addr{color:var(--faint);font-size:.78rem;margin-bottom:12px}\n.comp-detail .row{font-size:.88rem;margin-bottom:10px}\n.comp-detail .row b{color:var(--text)}\n.comp-detail .row span{color:var(--muted)}\n.comp-insight{grid-column:span 12;background:var(--green);color:#04150e}\n.comp-insight .eyebrow{color:#065f3c}\n.comp-insight p{font-size:1.05rem;line-height:1.5;margin-top:8px;max-width:80ch}\n.comp-insight b{font-weight:700}\n@media (max-width:860px){\n  .comp-lead,.comp-table,.comp-detail,.comp-insight{grid-column:1/-1}\n}\n@media (max-width:560px){\n  .comp-table thead th:nth-child(2),.comp-table tbody td:nth-child(2){display:none}\n}\n\n/* ===== PRESUPUESTO ===== */.budget-intro{grid-column:span 12;background:var(--purple);color:#160a2e}\n.budget-intro h2{font-family:\"Fraunces\";font-size:clamp(1.6rem,3vw,2.3rem);font-weight:600;letter-spacing:-.01em}\n.budget-intro p{font-size:.95rem;margin-top:10px;max-width:70ch;opacity:.8}\n\n.table-card{grid-column:span 12;background:var(--card);padding:0;overflow:hidden}\ntable{width:100%;border-collapse:collapse;font-size:.92rem}\nthead th{\n  text-align:left;padding:18px 22px;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;\n  color:var(--faint);font-weight:700;border-bottom:1px solid var(--line);\n}\nthead th.r{text-align:right}\ntbody td{padding:16px 22px;border-bottom:1px solid var(--line);vertical-align:top}\ntbody tr:last-child td{border-bottom:none}\ntbody td.r{text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap}\n.svc-name{font-weight:600}\n.svc-desc{color:var(--muted);font-size:.82rem;margin-top:3px;display:block}\n.badge{display:inline-block;font-size:.64rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 9px;border-radius:999px;vertical-align:middle;margin-left:8px}\n.badge.once{background:rgba(255,193,7,.16);color:var(--yellow)}\n.badge.mo{background:rgba(16,214,138,.16);color:var(--green)}\n.row-total td{background:var(--card-2);font-weight:700}\n.row-total td .amt{font-family:\"Fraunces\";font-size:1.15rem}\n.iva{color:var(--faint);font-size:.78rem;font-weight:400}\n\n/* totals bento */\n.tot{grid-column:span 4}\n.tot.dark{background:var(--card-2)}\n.tot.green{background:var(--green);color:#04150e}\n.tot.pink{background:var(--pink);color:#fff}\n.tot .lbl{font-size:.74rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;opacity:.8}\n.tot .amt{font-family:\"Fraunces\";font-size:2.5rem;font-weight:600;line-height:1;margin:12px 0 4px}\n.tot .note{font-size:.82rem;opacity:.75}\n\n/* notes */\n.notes{grid-column:span 8;background:var(--card)}\n.notes ul{list-style:none}\n.notes li{padding:11px 0;border-bottom:1px solid var(--line);font-size:.9rem;color:var(--muted);display:flex;gap:12px}\n.notes li:last-child{border-bottom:none}\n.notes li b{color:var(--text)}\n.notes .mk{color:var(--cyan);font-weight:700;flex-shrink:0}\n.notes-side{grid-column:span 4;background:var(--orange);color:#fff;display:flex;flex-direction:column;justify-content:center}\n.notes-side .big{font-family:\"Fraunces\";font-size:1.6rem;font-weight:600;line-height:1.1}\n.notes-side p{font-size:.85rem;opacity:.92;margin-top:10px}\n\n/* slogan */\n.slogan{grid-column:span 12;background:var(--ink);text-align:center;padding:46px 20px}\n.slogan .hand{font-size:clamp(2rem,5vw,3.4rem);color:var(--green);line-height:1}\n.slogan .lbl{font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--faint);margin-bottom:8px}\n\n/* footer */\n.foot{grid-column:span 12;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;padding-top:8px;color:var(--faint);font-size:.8rem}\n.foot .serif{color:var(--muted)}\n\n@media (max-width:860px){\n  .bento{grid-template-columns:repeat(6,1fr)}\n  .h-left,.h-right,.full,.table-card,.budget-intro,.slogan,.section-head,.foot{grid-column:1/-1}\n  .h-right{flex-direction:row}\n  .snap{grid-column:span 3}\n  .pain{grid-column:span 6}\n  .strat,.tot{grid-column:span 3}\n  .notes{grid-column:span 6}.notes-side{grid-column:span 6}\n  .full .grid2{grid-template-columns:1fr}\n}\n@media (max-width:560px){\n  :root{--gap:12px;--r:20px}\n  .h-right{flex-direction:column}\n  .snap,.pain,.strat,.tot,.notes,.notes-side{grid-column:1/-1}\n  thead th:nth-child(2),tbody td:nth-child(2){display:none}\n  .table-card{overflow-x:auto}\n}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n\n<!-- HERO -->\n<div class=\"bento hero\">\n  <div class=\"card h-left\">\n    <div>\n      <div class=\"brandmark\"><span class=\"slash\">/</span>bidaman<span class=\"lab\">creative lab</span></div>\n    </div>\n    <div class=\"h-title\">Brief estratégico <em>+</em> presupuesto<br>para <span class=\"serif\">Kinecenter&nbsp;MX</span></div>\n  </div>\n  <div class=\"h-right\">\n    <div class=\"card h-card-pink\">\n      <span class=\"chip\">Diagnóstico</span>\n      <div class=\"big\">52</div>\n      <div class=\"lbl\">seguidores en Instagram · 15 posts publicados</div>\n    </div>\n    <div class=\"card h-card-dark\">\n      <p class=\"meta\">\n        <b>Centro de rehabilitación</b> enfocado a la prevención, tratamiento y\n        rehabilitación de las enfermedades del sistema musculoesquelético y al\n        desempeño físico. <b>Enfoque clínico, no es un spa.</b><br><br>\n        <b>C. Taxco 32, Roma Sur, Cuauhtémoc, CDMX 06760.</b> Sólo Facebook e\n        Instagram; sin sitio web activo, correo normal y dominio\n        <b>kinecenter.com</b> a recuperar.\n      </p>\n    </div>\n  </div>\n</div>\n\n<!-- SNAPSHOT -->\n<div class=\"bento\">\n  <div class=\"section-head\">\n    <span class=\"num\">01</span>\n    <h2 class=\"serif\">Dónde está parado el negocio hoy</h2>\n    <p>Resumen del estado actual de la presencia digital, basado en sus perfiles públicos de Facebook e Instagram y en el comparativo con clínicas competidoras de su zona en Ciudad de México (Roma, Condesa, Polanco).</p>\n  </div>\n\n  <div class=\"card snap green\">\n    <div class=\"n\">2</div>\n    <div class=\"k\">Canales activos</div>\n    <div class=\"sub\">Sólo Facebook + Instagram. Cero sitio web.</div>\n  </div>\n  <div class=\"card snap cyan\">\n    <div class=\"n\">~15</div>\n    <div class=\"k\">Publicaciones IG</div>\n    <div class=\"sub\">Volumen muy bajo; sin ritmo constante.</div>\n  </div>\n  <div class=\"card snap yellow\">\n    <div class=\"n\">2,949</div>\n    <div class=\"k\">Competencia en Roma Sur (Up Therapy)</div>\n    <div class=\"sub\">Clínicas vecinas en CDMX ya rebasan los 2,700 seguidores.</div>\n  </div>\n  <div class=\"card snap orange\">\n    <div class=\"n\">0</div>\n    <div class=\"k\">Inversión en pauta</div>\n    <div class=\"sub\">Crecimiento 100% orgánico y estancado.</div>\n  </div>\n</div>\n\n<!-- PANORAMA COMPETITIVO -->\n<div class=\"bento\">\n  <div class=\"section-head\">\n    <span class=\"num\">02</span>\n    <h2 class=\"serif\">Panorama competitivo en Roma Sur</h2>\n    <p>Ranking de las clínicas clave cercanas a C. Taxco 32, ordenadas por efectividad de su estilo de comunicación y por su cercanía al modelo de negocio y posicionamiento de Kinecenter MX.</p>\n  </div>\n\n  <div class=\"card comp-lead\">\n    <span class=\"eyebrow\">Cómo se lee</span>\n    <h3 class=\"serif\">5 clínicas, mismo radio.</h3>\n    <p>Estrellas = qué tan efectiva es su comunicación pública. La etiqueta de similitud indica qué tanto se parece su modelo y tono al de Kinecenter.</p>\n  </div>\n\n  <div class=\"card comp-table\">\n    <table>\n      <thead>\n        <tr>\n          <th>Clínica / dirección</th>\n          <th>Comunicación</th>\n          <th>Similitud</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr class=\"ref\">\n          <td><span class=\"cl-name\">Kinecenter MX</span><span class=\"cl-addr\">Taxco 32 · referencia</span></td>\n          <td><span class=\"stars\">★★<span class=\"off\">★★★</span></span></td>\n          <td><span class=\"sim ref\">Referencia</span></td>\n        </tr>\n        <tr>\n          <td><span class=\"cl-name\">Physiosalud</span><span class=\"cl-addr\">Medellín 219, Roma Sur</span></td>\n          <td><span class=\"stars\">★★★★<span class=\"off\">★</span></span></td>\n          <td><span class=\"sim high\">Alta</span></td>\n        </tr>\n        <tr>\n          <td><span class=\"cl-name\">Fisioliver</span><span class=\"cl-addr\">Tepic 126, Roma Sur</span></td>\n          <td><span class=\"stars\">★★★★<span class=\"off\">★</span></span></td>\n          <td><span class=\"sim high\">Alta</span></td>\n        </tr>\n        <tr>\n          <td><span class=\"cl-name\">UP Therapy MX</span><span class=\"cl-addr\">Tepic 139, Roma Sur</span></td>\n          <td><span class=\"stars\">★★★<span class=\"off\">★★</span></span></td>\n          <td><span class=\"sim mid\">Media</span></td>\n        </tr>\n        <tr>\n          <td><span class=\"cl-name\">Unidad Médica de Rehabilitación</span><span class=\"cl-addr\">Tehuantepec 214, Roma Sur</span></td>\n          <td><span class=\"stars\">★★★<span class=\"off\">★★</span></span></td>\n          <td><span class=\"sim low\">Baja–Media</span></td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <div class=\"card comp-detail\">\n    <h3><span class=\"rank\">02</span> Physiosalud</h3>\n    <div class=\"addr\">Medellín 219, Roma Sur</div>\n    <div class=\"row\"><b>Comunicación:</b> <span>cálida, clara y educativa. Subraya \"comunicación clara, trato cálido y ética profesional\", con descripciones de servicio explícitas y horarios extendidos. Más formal y clínica en el tono.</span></div>\n    <div class=\"row\"><b>Modelo:</b> <span>alta efectividad por claridad y empatía. Coincide en rehabilitación y fisioterapia deportiva, pero se apoya más en la educación al paciente y su familia y en la disponibilidad de jornada completa, algo que Kinecenter sugiere pero no destaca tanto.</span></div>\n  </div>\n\n  <div class=\"card comp-detail\">\n    <h3><span class=\"rank\">03</span> Fisioliver</h3>\n    <div class=\"addr\">Tepic 126, Roma Sur</div>\n    <div class=\"row\"><b>Comunicación:</b> <span>relacional y centrada en el paciente. El sitio busca explícitamente \"establecer un vínculo cercano con el paciente\" para favorecer la adherencia, con un tono cálido y algo personal.</span></div>\n    <div class=\"row\"><b>Modelo:</b> <span>fuerte conexión emocional y enfoque en la relación terapéutica, pero con menos branding público y menos ganchos tipo redes sociales. Mismo nicho de rehabilitación, con marketing menos orientado al crecimiento.</span></div>\n  </div>\n\n  <div class=\"card comp-detail\">\n    <h3><span class=\"rank\">04</span> UP Therapy MX</h3>\n    <div class=\"addr\">Tepic 139, Roma Sur</div>\n    <div class=\"row\"><b>Comunicación:</b> <span>orientada a resultados y funcional-profesional. Su copy público es más de listado de servicios que emocional o relacional; se lee más como directorio que como marca.</span></div>\n    <div class=\"row\"><b>Modelo:</b> <span>similitud media en tipo de servicio (fisioterapia y rehabilitación deportiva), pero con tono menos personal y menos branded. Posible traslape en rehabilitación deportiva y de lesiones.</span></div>\n  </div>\n\n  <div class=\"card comp-detail\">\n    <h3><span class=\"rank\">05</span> Unidad Médica de Rehabilitación</h3>\n    <div class=\"addr\">Tehuantepec 214, Roma Sur</div>\n    <div class=\"row\"><b>Comunicación:</b> <span>más institucional / médica. Se presenta como \"unidad médica de rehabilitación\", lo que sugiere un tono formal y clínico más que una voz lúdica o de estilo de vida.</span></div>\n    <div class=\"row\"><b>Modelo:</b> <span>similitud baja-media en estilo de comunicación: es más \"unidad médica\" que estudio de rehabilitación cercano a la comunidad. Comparte el nicho, pero apunta a un público más de derivación médica general que directo al consumidor.</span></div>\n  </div>\n\n  <div class=\"card comp-insight\">\n    <span class=\"eyebrow\">Lectura estratégica</span>\n    <p><b>Physiosalud y Fisioliver son las más alineadas</b> con Kinecenter en espíritu de comunicación y modelo de negocio, mientras que <b>UP Therapy y la Unidad Médica</b> se inclinan a lo neutral o médico-institucional. El espacio que Kinecenter puede ganar: una voz directa, visual y cercana (enfoque clínico con tono de estilo de vida) que hoy nadie en el radio inmediato ocupa del todo.</p>\n  </div>\n</div>\n\n<!-- PAIN POINTS -->\n<div class=\"bento\">\n  <div class=\"section-head\">\n    <span class=\"num\">03</span>\n    <h2 class=\"serif\">Pain points principales en redes</h2>\n    <p>Los puntos de dolor que frenan el crecimiento de Kinecenter en Facebook e Instagram, priorizados por impacto.</p>\n  </div>\n\n  <div class=\"card pain\">\n    <span class=\"tag\">Visibilidad</span>\n    <h3>Alcance casi nulo</h3>\n    <p>Con ~52 seguidores y 15 posts, el perfil no aparece en búsquedas ni recomendaciones. La competencia local ya juega en otra liga de volumen y constancia.</p>\n  </div>\n  <div class=\"card pain\">\n    <span class=\"tag\">Contenido</span>\n    <h3>Sin sistema de contenido</h3>\n    <p>Publicaciones esporádicas y sin línea editorial. No hay reels/tiktoks temáticos constantes, justo el formato que genera alcance hoy y el que la clínica quiere priorizar.</p>\n  </div>\n  <div class=\"card pain\">\n    <span class=\"tag\">Identidad</span>\n    <h3>Branding desactualizado</h3>\n    <p>Falta paleta de color, base visual y un estilo digital reconocible. El mensaje \"enfoque clínico, no spa\" no se comunica visualmente; se diluye frente a centros estéticos.</p>\n  </div>\n  <div class=\"card pain\">\n    <span class=\"tag\">Posicionamiento</span>\n    <h3>Nicho sin explotar</h3>\n    <p>Públicos claros (postoperados, adultos mayores impulsados por sus hijos, derivaciones de médicos ortopedistas) que hoy no se trabajan con mensajes segmentados ni pauta.</p>\n  </div>\n</div>\n\n<!-- UNDERSTANDING -->\n<div class=\"bento\">\n  <div class=\"section-head\">\n    <span class=\"num\">04</span>\n    <h2 class=\"serif\">Lo que entendimos del negocio</h2>\n  </div>\n  <div class=\"card full\">\n    <div class=\"grid2\">\n      <div>\n        <p class=\"eyebrow\" style=\"margin-bottom:14px\">Quiénes son y qué quieren</p>\n        <ul>\n          <li><span class=\"dot\">→</span><span><b>Clínica de rehabilitación</b> con enfoque médico. Recuperación de operaciones (rodilla) y fibromialgia.</span></li>\n          <li><span class=\"dot\">→</span><span><b>Fuente de pacientes:</b> médicos ortopedistas que derivan a la clínica.</span></li>\n          <li><span class=\"dot\">→</span><span><b>2 ramas:</b> masajes y máquina de rehabilitación con calor infrarrojo (Photon) para desinflamar.</span></li>\n          <li><span class=\"dot\">→</span><span><b>Públicos:</b> adultos mayores (impulsados por sus hijos), postoperados, quien busca quitarse el dolor.</span></li>\n          <li><span class=\"dot\">→</span><span><b>Quieren más video:</b> reels y tiktoks temáticos, 2 por semana, formato corto.</span></li>\n        </ul>\n      </div>\n      <div>\n        <p class=\"eyebrow\" style=\"margin-bottom:14px\">Reglas y límites del proyecto</p>\n        <ul class=\"neg\">\n          <li><span class=\"dot\">✕</span><span><b>No es un spa.</b> El tono debe ser clínico y profesional, no de bienestar estético.</span></li>\n          <li><span class=\"dot\">✕</span><span><b>No publicidad tipo página web:</b> prefieren pauta a tener sitio.</span></li>\n          <li><span class=\"dot\">✕</span><span><b>No servicios de WhatsApp</b> dentro del alcance.</span></li>\n          <li><span class=\"dot\">✕</span><span>No hay quién grabe internamente; <b>se puede mandar a alguien</b> a grabar.</span></li>\n          <li><span class=\"dot\">✕</span><span>Mantener <b>accesos a redes intactos</b> y <b>recuperar el dominio</b> kinecenter.com.</span></li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- STRATEGY -->\n<div class=\"bento\">\n  <div class=\"section-head\">\n    <span class=\"num\">05</span>\n    <h2 class=\"serif\">Cómo lo vamos a resolver</h2>\n    <p>Tres frentes de trabajo que atacan directamente los pain points anteriores.</p>\n  </div>\n  <div class=\"card strat\">\n    <div class=\"ic\" style=\"background:var(--orange)\">A</div>\n    <h3>Rebranding express</h3>\n    <p>Nuevos colores y base visual con estilo digital reconocible. Refresh de la identidad en redes para diferenciar a Kinecenter como clínica seria. <b>Se realiza una sola vez.</b></p>\n  </div>\n  <div class=\"card strat\">\n    <div class=\"ic\" style=\"background:var(--cyan)\">B</div>\n    <h3>Motor de contenido</h3>\n    <p>Producción y edición de reels/tiktoks temáticos (2 por semana, 8 al mes) con calendario editorial enfocado en ejercicios, recuperación y casos clínicos.</p>\n  </div>\n  <div class=\"card strat\">\n    <div class=\"ic\" style=\"background:var(--yellow)\">C</div>\n    <h3>Pauta + administración</h3>\n    <p>Posteo y colocación de pautas segmentadas a los nichos correctos, más administración mensual de las cuentas para medir y ajustar.</p>\n  </div>\n</div>\n\n<!-- BUDGET -->\n<div class=\"bento\">\n  <div class=\"card budget-intro\">\n    <span class=\"eyebrow\" style=\"color:#3d1d6e\">06 · Inversión</span>\n    <h2 class=\"serif\">Presupuesto</h2>\n    <p>Todas las cantidades <b>incluyen IVA (16%)</b>. El rebranding express es un cargo único de arranque; el resto es mensual recurrente. Facturación disponible.</p>\n  </div>\n\n  <div class=\"card table-card\">\n    <table>\n      <thead>\n        <tr>\n          <th>Concepto</th>\n          <th>Detalle</th>\n          <th class=\"r\">Importe (IVA incl.)</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td>\n            <span class=\"svc-name\">Rebranding express</span><span class=\"badge once\">Único</span>\n            <span class=\"svc-desc\">Colores y base visual · estilo digital · refresh de identidad en redes</span>\n          </td>\n          <td><span class=\"iva\">Pago único de arranque</span></td>\n          <td class=\"r\">$3,242.19</td>\n        </tr>\n        <tr>\n          <td>\n            <span class=\"svc-name\">Editor de reels / tiktoks</span><span class=\"badge mo\">Mensual</span>\n            <span class=\"svc-desc\">Edición de video formato corto · 8 piezas al mes</span>\n          </td>\n          <td><span class=\"iva\">Producción de contenido</span></td>\n          <td class=\"r\">$2,350.59</td>\n        </tr>\n        <tr>\n          <td>\n            <span class=\"svc-name\">Posteo + colocación de pautas</span><span class=\"badge mo\">Mensual</span>\n            <span class=\"svc-desc\">2 por semana · 8 al mes · segmentación a nichos</span>\n          </td>\n          <td><span class=\"iva\">Gestión de campañas</span></td>\n          <td class=\"r\">$1,658.30</td>\n        </tr>\n        <tr>\n          <td>\n            <span class=\"svc-name\">Administración de cuentas</span><span class=\"badge mo\">Mensual</span>\n            <span class=\"svc-desc\">Gestión, medición y ajuste de perfiles</span>\n          </td>\n          <td><span class=\"iva\">Operación</span></td>\n          <td class=\"r\">$1,535.69</td>\n        </tr>\n        <tr class=\"row-total\">\n          <td colspan=\"2\">Total mensual recurrente <span class=\"iva\">(servicios, sin incluir pauta publicitaria)</span></td>\n          <td class=\"r\"><span class=\"amt\">$5,544.58</span></td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <!-- TOTALS -->\n  <div class=\"card tot dark\">\n    <div class=\"lbl\" style=\"color:var(--yellow)\">Arranque · pago único</div>\n    <div class=\"amt\">$3,242<span style=\"font-size:1.2rem\">.19</span></div>\n    <div class=\"note\">Rebranding express. Se cobra una sola vez al inicio del proyecto.</div>\n  </div>\n  <div class=\"card tot green\">\n    <div class=\"lbl\">Mensual · servicios</div>\n    <div class=\"amt\">$5,544<span style=\"font-size:1.2rem\">.58</span></div>\n    <div class=\"note\">Editor + posteo/pautas + administración. IVA incluido.</div>\n  </div>\n  <div class=\"card tot pink\">\n    <div class=\"lbl\">+ Pauta publicitaria sugerida</div>\n    <div class=\"amt\" style=\"font-size:1.9rem\">$1,500<span style=\"font-size:1.1rem\">–</span>$2,000</div>\n    <div class=\"note\">Inversión mensual recomendada en anuncios (la fija el cliente).</div>\n  </div>\n</div>\n\n<!-- NOTES -->\n<div class=\"bento\">\n  <div class=\"card notes\">\n    <p class=\"eyebrow\" style=\"margin-bottom:14px\">Consideraciones incluidas</p>\n    <ul>\n      <li><span class=\"mk\">●</span><span><b>Facturación:</b> sí, con IVA al 16% ya contemplado en cada concepto.</span></li>\n      <li><span class=\"mk\">●</span><span><b>Dominio:</b> se intentará recuperar <b>kinecenter.com</b> (2 años sin pagar). Si se reactiva, puede haber un costo de redención del registrador, fuera de este presupuesto.</span></li>\n      <li><span class=\"mk\">●</span><span><b>Pauta:</b> entre $1,500 y $2,000 MXN mensuales de inversión directa en anuncios, no honorarios; se recomiendan pero los define Kinecenter.</span></li>\n      <li><span class=\"mk\">●</span><span><b>Grabación:</b> de requerirse traslado de alguien a grabar in situ, se cotiza aparte según frecuencia.</span></li>\n    </ul>\n  </div>\n  <div class=\"card notes-side\">\n    <div class=\"big serif\">Inversión inicial</div>\n    <p>Primer mes = rebranding ($3,242.19) + servicios ($5,544.58) = <b>$8,786.77</b>. Sumando pauta sugerida: <b>$10,286.77 – $10,786.77</b>.</p>\n  </div>\n</div>\n\n<!-- SLOGAN -->\n<div class=\"bento\">\n  <div class=\"card slogan\">\n    <div class=\"lbl\">Slogan</div>\n    <div class=\"hand\">Dale movimiento a tu vida.</div>\n  </div>\n</div>\n\n<!-- FOOTER -->\n<div class=\"bento\">\n  <div class=\"foot\">\n    <div class=\"serif\"><span class=\"slash\">/</span>bidaman, creative lab</div>\n    <div>Brief + presupuesto · Kinecenter MX · cifras con IVA (16%) incluido</div>\n  </div>\n</div>\n\n</div>\n</body>\n</html>\n"}]